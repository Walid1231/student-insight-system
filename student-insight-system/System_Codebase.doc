<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile | Teacher Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="{{ url_for('static', filename='css/dashboard.css') }}" rel="stylesheet">
    <script>if (localStorage.getItem('teacher_theme') === 'dark') document.documentElement.setAttribute('data-theme', 'dark');</script>
    <link href="{{ url_for('static', filename='css/ui_alerts.css') }}" rel="stylesheet">
    <script src="{{ url_for('static', filename='js/ui_alerts.js') }}"></script>
    <style>
        /* ── Page Layout ── */
        .profile-page {
            max-width: 860px;
            margin: 0 auto;
            padding-bottom: 60px;
        }

        /* ── Hero Card ── */
        .profile-hero-card {
            background: linear-gradient(135deg, #002D62 0%, #004080 60%, #00529b 100%);
            border-radius: 20px;
            padding: 40px 44px;
            display: flex;
            align-items: center;
            gap: 36px;
            margin-bottom: 28px;
            position: relative;
            overflow: hidden;
            box-shadow: 0 8px 32px rgba(0, 45, 98, 0.22);
        }

        .profile-hero-card::before {
            content: '';
            position: absolute;
            top: -40px;
            right: -40px;
            width: 200px;
            height: 200px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.06);
        }

        .profile-hero-card::after {
            content: '';
            position: absolute;
            bottom: -60px;
            left: 40%;
            width: 300px;
            height: 300px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.04);
        }

        /* ── Avatar ── */
        .avatar-wrap {
            position: relative;
            flex-shrink: 0;
            z-index: 1;
        }

        .avatar-img {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            object-fit: cover;
            border: 4px solid rgba(255, 255, 255, 0.3);
            background: rgba(255, 255, 255, 0.15);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 46px;
            color: white;
            font-weight: 700;
            letter-spacing: -1px;
        }

        .avatar-upload-btn {
            position: absolute;
            bottom: 4px;
            right: 4px;
            width: 30px;
            height: 30px;
            background: white;
            border-radius: 50%;
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
            transition: transform 0.2s;
        }

        .avatar-upload-btn:hover {
            transform: scale(1.1);
        }

        .avatar-upload-btn i {
            width: 14px;
            height: 14px;
            color: #002D62;
        }

        #picInput {
            display: none;
        }

        /* ── Hero Text ── */
        .hero-info {
            z-index: 1;
            flex: 1;
        }

        .hero-name {
            font-size: 26px;
            font-weight: 800;
            color: white;
            margin: 0 0 4px;
            letter-spacing: -0.3px;
        }

        .hero-designation {
            font-size: 14px;
            color: rgba(255, 255, 255, 0.75);
            margin-bottom: 14px;
            font-weight: 500;
        }

        .hero-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .hero-tag {
            background: rgba(255, 255, 255, 0.15);
            color: white;
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 20px;
            padding: 4px 14px;
            font-size: 12px;
            font-weight: 500;
            backdrop-filter: blur(4px);
        }

        .edit-profile-btn {
            margin-left: auto;
            flex-shrink: 0;
            z-index: 1;
            background: rgba(255, 255, 255, 0.15);
            border: 1.5px solid rgba(255, 255, 255, 0.35);
            color: white;
            border-radius: 10px;
            padding: 10px 22px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            backdrop-filter: blur(4px);
            transition: background 0.2s;
            display: flex;
            align-items: center;
            gap: 7px;
        }

        .edit-profile-btn:hover {
            background: rgba(255, 255, 255, 0.25);
        }

        .edit-profile-btn i {
            width: 15px;
            height: 15px;
        }

        /* ── Info Cards ── */
        .info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 20px;
        }

        .info-card {
            background: var(--bg-card, #fff);
            border: 1px solid var(--border, #e5e7eb);
            border-radius: 14px;
            padding: 24px 26px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
        }

        .info-card.full {
            grid-column: 1 / -1;
        }

        .info-card-title {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.7px;
            color: var(--text-muted, #9ca3af);
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 7px;
        }

        .info-card-title i {
            width: 14px;
            height: 14px;
            color: var(--primary, #6366f1);
        }

        .info-row {
            display: flex;
            flex-direction: column;
            gap: 3px;
            padding: 11px 0;
            border-bottom: 1px solid var(--border, #f3f4f6);
        }

        .info-row:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

        .info-row:first-child {
            padding-top: 0;
        }

        .info-label {
            font-size: 11px;
            color: var(--text-muted, #9ca3af);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .info-value {
            font-size: 14px;
            color: var(--text-primary, #111827);
            font-weight: 500;
            word-break: break-word;
        }

        .info-value.empty {
            color: var(--text-muted, #9ca3af);
            font-style: italic;
            font-weight: 400;
        }

        .info-value a {
            color: var(--primary, #6366f1);
            text-decoration: none;
        }

        .info-value a:hover {
            text-decoration: underline;
        }

        /* ── Edit Panel ── */
        #editPanel {
            display: none;
            background: var(--bg-card, #fff);
            border: 1px solid var(--border, #e5e7eb);
            border-radius: 14px;
            padding: 32px 34px;
            margin-bottom: 20px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
        }

        .edit-panel-title {
            font-size: 16px;
            font-weight: 700;
            color: var(--text-primary, #111827);
            margin-bottom: 24px;
            display: flex;
            align-items: center;
            gap: 9px;
        }

        .edit-panel-title i {
            width: 18px;
            height: 18px;
            color: var(--primary, #6366f1);
        }

        .edit-form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px 22px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .form-group.full {
            grid-column: 1 / -1;
        }

        .form-label {
            font-size: 12px;
            font-weight: 600;
            color: var(--text-secondary, #6b7280);
        }

        .form-input {
            padding: 10px 14px;
            border: 1.5px solid var(--border, #e5e7eb);
            border-radius: 9px;
            font-size: 14px;
            font-family: inherit;
            background: var(--bg-surface, #f9fafb);
            color: var(--text-primary, #111827);
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .form-input:focus {
            outline: none;
            border-color: #6366f1;
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.12);
            background: white;
        }

        .edit-actions {
            display: flex;
            justify-content: flex-end;
            gap: 12px;
            margin-top: 24px;
        }

        .btn-save {
            background: linear-gradient(90deg, #6366f1, #8b5cf6);
            color: white;
            border: none;
            border-radius: 9px;
            padding: 10px 28px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: opacity 0.2s;
        }

        .btn-save:hover {
            opacity: 0.88;
        }

        .btn-cancel {
            background: transparent;
            border: 1.5px solid var(--border, #e5e7eb);
            border-radius: 9px;
            padding: 10px 22px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            color: var(--text-secondary, #6b7280);
        }

        .btn-cancel:hover {
            background: var(--bg-surface, #f9fafb);
        }

        @media (max-width: 640px) {
            .profile-hero-card {
                flex-direction: column;
                text-align: center;
                padding: 28px 20px;
            }

            .hero-tags {
                justify-content: center;
            }

            .edit-profile-btn {
                margin-left: 0;
            }

            .info-grid,
            .edit-form-grid {
                grid-template-columns: 1fr;
            }

            .info-card.full {
                grid-column: 1;
            }

            .form-group.full {
                grid-column: 1;
            }
        }

        /* Dark mode overrides for profile-specific elements */
        html[data-theme="dark"] .info-card {
            background: #1a1d27;
            border-color: #2d3241;
        }

        html[data-theme="dark"] .info-value {
            color: #e5e7eb;
        }

        html[data-theme="dark"] .info-value.empty {
            color: #6b7280;
        }

        html[data-theme="dark"] .info-label {
            color: #9ca3af;
        }

        html[data-theme="dark"] .info-card-title {
            color: #9ca3af;
        }

        html[data-theme="dark"] .info-row {
            border-bottom-color: #2d3241;
        }

        html[data-theme="dark"] #editPanel {
            background: #1a1d27;
            border-color: #2d3241;
        }

        html[data-theme="dark"] .edit-panel-title {
            color: #f3f4f6;
        }

        html[data-theme="dark"] .form-input {
            background: #141720;
            border-color: #2d3241;
            color: #e5e7eb;
        }

        html[data-theme="dark"] .form-input:focus {
            background: #1e2231;
            border-color: #6366f1;
        }

        html[data-theme="dark"] .form-label {
            color: #9ca3af;
        }

        html[data-theme="dark"] .btn-cancel {
            border-color: #2d3241;
            color: #9ca3af;
        }

        html[data-theme="dark"] .btn-cancel:hover {
            background: #1e2231;
        }
    </style>
</head>

<body>
    <!-- Sidebar Toggle Button -->
    <button class="sidebar-toggle" onclick="toggleSidebar()" aria-label="Toggle Sidebar" id="sidebarToggle">
        <i data-lucide="menu"></i>
    </button>
    <!-- Mobile Backdrop -->
    <div id="sidebarBackdrop" onclick="closeSidebar()"
        style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:1999;"></div>

    <nav class="sidebar">
        <div class="logo">Teacher Dashboard</div>
        <div class="nav-links">
            <a href="/teacher/dashboard" class="nav-item">
                <span class="nav-icon"><i data-lucide="layout-dashboard"></i></span> Dashboard
            </a>
            <a href="/teacher/students" class="nav-item">
                <span class="nav-icon"><i data-lucide="users"></i></span> Students
            </a>
            <a href="/teacher/alerts" class="nav-item">
                <span class="nav-icon"><i data-lucide="bell"></i></span> Alerts
            </a>
            <a href="/teacher/notes" class="nav-item">
                <span class="nav-icon"><i data-lucide="file-text"></i></span> My Notes
            </a>
            <a href="/teacher/profile" class="nav-item active">
                <span class="nav-icon"><i data-lucide="user"></i></span> My Profile
            </a>
        </div>
        <div class="sidebar-footer">
            <a href="/logout" class="nav-item" style="color: var(--danger);">
                <span class="nav-icon"><i data-lucide="log-out"></i></span> Logout
            </a>
        </div>
    </nav>

    <div class="main-content">
        <div class="header">
            <div>
                <h1>My Profile</h1>
                <p style="color:var(--gray-500)">View and manage your faculty profile information.</p>
            </div>
            <div style="display:flex; align-items:center; gap:12px; font-size:14px; color:var(--gray-500)">
                {{ now_date }}
                <button class="dm-toggle" id="dmToggle" onclick="toggleDarkMode()" title="Toggle dark mode">
                    <i data-lucide="moon" id="dmIcon"></i>
                </button>
            </div>
        </div>

        <div class="profile-page">

            <!-- ── Hero Card ── -->
            <div class="profile-hero-card">
                <!-- Avatar -->
                <div class="avatar-wrap">
                    {% if teacher.profile_picture %}
                    <img id="avatarImg" class="avatar-img"
                        src="{{ url_for('static', filename='uploads/teacher_pics/' + teacher.profile_picture) }}"
                        alt="{{ teacher.full_name }}">
                    {% else %}
                    <div id="avatarImg" class="avatar-img">
                        {{ teacher.full_name[:2].upper() if teacher.full_name else 'TC' }}
                    </div>
                    {% endif %}
                    <button class="avatar-upload-btn" onclick="document.getElementById('picInput').click()"
                        title="Change photo">
                        <i data-lucide="camera"></i>
                    </button>
                    <input type="file" id="picInput" accept="image/*" onchange="uploadPicture(this)">
                </div>

                <!-- Info -->
                <div class="hero-info">
                    <div class="hero-name" id="heroName">{{ teacher.full_name }}</div>
                    <div class="hero-designation" id="heroDesignation">
                        {{ teacher.designation or 'No designation set' }}
                    </div>
                    <div class="hero-tags">
                        {% if teacher.department %}
                        <span class="hero-tag">
                            <i data-lucide="building-2"
                                style="width:11px;height:11px;display:inline;margin-right:4px;"></i>
                            {{ teacher.department }}
                        </span>
                        {% endif %}
                        {% if teacher.faculty %}
                        <span class="hero-tag">{{ teacher.faculty }}</span>
                        {% endif %}
                        {% if teacher.subject_specialization %}
                        <span class="hero-tag">{{ teacher.subject_specialization }}</span>
                        {% endif %}
                    </div>
                </div>

                <!-- Edit Button -->
                <button class="edit-profile-btn" onclick="toggleEdit()">
                    <i data-lucide="pencil"></i> Edit Profile
                </button>
            </div>

            <!-- ── Edit Panel ── -->
            <div id="editPanel">
                <div class="edit-panel-title">
                    <i data-lucide="pencil"></i> Edit Profile Information
                </div>
                <div class="edit-form-grid">
                    <div class="form-group">
                        <label class="form-label">Full Name</label>
                        <input class="form-input" id="f_full_name" type="text" value="{{ teacher.full_name or '' }}"
                            placeholder="Prof. Dr. John Smith">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Designation</label>
                        <input class="form-input" id="f_designation" type="text" value="{{ teacher.designation or '' }}"
                            placeholder="Dean / Associate Professor / Lecturer">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Department</label>
                        <input class="form-input" id="f_department" type="text" value="{{ teacher.department or '' }}"
                            placeholder="Department of Marketing">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Faculty</label>
                        <input class="form-input" id="f_faculty" type="text" value="{{ teacher.faculty or '' }}"
                            placeholder="Faculty of Business & Entrepreneurship">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Subject Specialization</label>
                        <input class="form-input" id="f_subject_specialization" type="text"
                            value="{{ teacher.subject_specialization or '' }}"
                            placeholder="e.g. Data Science, Marketing">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Personal Webpage</label>
                        <input class="form-input" id="f_personal_webpage" type="url"
                            value="{{ teacher.personal_webpage or '' }}"
                            placeholder="https://faculty.university.edu/profile/...">
                    </div>
                    <div class="form-group full">
                        <label class="form-label">Email Address(es)</label>
                        <input class="form-input" id="f_email" type="text" value="{{ teacher.email or '' }}"
                            placeholder="dean@university.edu, head@university.edu">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Phone (Office)</label>
                        <input class="form-input" id="f_phone" type="tel" value="{{ teacher.phone or '' }}"
                            placeholder="e.g. 65107">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Cell Phone</label>
                        <input class="form-input" id="f_cell_phone" type="tel" value="{{ teacher.cell_phone or '' }}"
                            placeholder="e.g. 01847140191">
                    </div>
                </div>
                <div class="edit-actions">
                    <button class="btn-cancel" onclick="toggleEdit()">Cancel</button>
                    <button class="btn-save" onclick="saveProfile()">
                        <i data-lucide="check" style="width:14px;height:14px;display:inline;margin-right:5px;"></i>
                        Save Changes
                    </button>
                </div>
            </div>

            <!-- ── Info Cards ── -->
            <div class="info-grid">

                <!-- Contact Information -->
                <div class="info-card">
                    <div class="info-card-title">
                        <i data-lucide="mail"></i> Contact Information
                    </div>
                    <div class="info-row">
                        <div class="info-label">Email</div>
                        <div class="info-value {{ 'empty' if not teacher.email }}">
                            {{ teacher.email or 'Not set' }}
                        </div>
                    </div>
                    <div class="info-row">
                        <div class="info-label">Phone (Office)</div>
                        <div class="info-value {{ 'empty' if not teacher.phone }}">
                            {{ teacher.phone or 'Not set' }}
                        </div>
                    </div>
                    <div class="info-row">
                        <div class="info-label">Cell Phone</div>
                        <div class="info-value {{ 'empty' if not teacher.cell_phone }}">
                            {{ teacher.cell_phone or 'Not set' }}
                        </div>
                    </div>
                </div>

                <!-- Academic Information -->
                <div class="info-card">
                    <div class="info-card-title">
                        <i data-lucide="graduation-cap"></i> Academic Information
                    </div>
                    <div class="info-row">
                        <div class="info-label">Designation</div>
                        <div class="info-value {{ 'empty' if not teacher.designation }}">
                            {{ teacher.designation or 'Not set' }}
                        </div>
                    </div>
                    <div class="info-row">
                        <div class="info-label">Department</div>
                        <div class="info-value {{ 'empty' if not teacher.department }}">
                            {{ teacher.department or 'Not set' }}
                        </div>
                    </div>
                    <div class="info-row">
                        <div class="info-label">Faculty</div>
                        <div class="info-value {{ 'empty' if not teacher.faculty }}">
                            {{ teacher.faculty or 'Not set' }}
                        </div>
                    </div>
                    <div class="info-row">
                        <div class="info-label">Specialization</div>
                        <div class="info-value {{ 'empty' if not teacher.subject_specialization }}">
                            {{ teacher.subject_specialization or 'Not set' }}
                        </div>
                    </div>
                </div>

                <!-- Personal Webpage (full width) -->
                <div class="info-card full">
                    <div class="info-card-title">
                        <i data-lucide="globe"></i> Personal Webpage
                    </div>
                    {% if teacher.personal_webpage %}
                    <div class="info-value">
                        <a href="{{ teacher.personal_webpage }}" target="_blank" rel="noopener">
                            {{ teacher.personal_webpage }}
                        </a>
                    </div>
                    {% else %}
                    <div class="info-value empty">No personal webpage set. Click Edit Profile to add one.</div>
                    {% endif %}
                </div>

            </div>
        </div>
    </div>

    <script>
        // ── Sidebar (same as other teacher pages) ──
        function toggleSidebar() {
            const isMobile = window.innerWidth <= 768;
            const sidebar = document.querySelector('nav.sidebar');
            const backdrop = document.getElementById('sidebarBackdrop');
            if (isMobile) {
                const isOpen = sidebar.classList.toggle('open');
                if (backdrop) backdrop.style.display = isOpen ? 'block' : 'none';
            } else {
                const mainContent = document.querySelector('.main-content');
                const isCollapsed = sidebar.classList.toggle('collapsed');
                document.body.classList.toggle('sidebar-collapsed', isCollapsed);
                if (mainContent) mainContent.classList.toggle('expanded', isCollapsed);
                localStorage.setItem('sidebarCollapsed', isCollapsed);
            }
        }
        function closeSidebar() {
            const sidebar = document.querySelector('nav.sidebar');
            const backdrop = document.getElementById('sidebarBackdrop');
            if (sidebar) sidebar.classList.remove('open');
            if (backdrop) backdrop.style.display = 'none';
        }
        window.addEventListener('DOMContentLoaded', () => {
            if (window.innerWidth > 768) {
                const isCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';
                if (isCollapsed) {
                    const sidebar = document.querySelector('nav.sidebar');
                    const mainContent = document.querySelector('.main-content');
                    if (sidebar) sidebar.classList.add('collapsed');
                    if (mainContent) mainContent.classList.add('expanded');
                    document.body.classList.add('sidebar-collapsed');
                }
            }
        });

        // ── Edit Toggle ──
        function toggleEdit() {
            const panel = document.getElementById('editPanel');
            panel.style.display = panel.style.display === 'block' ? 'none' : 'block';
            if (panel.style.display === 'block') {
                panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        }

        // ── Save Profile ──
        async function saveProfile() {
            const body = {
                full_name: document.getElementById('f_full_name').value.trim(),
                designation: document.getElementById('f_designation').value.trim(),
                department: document.getElementById('f_department').value.trim(),
                faculty: document.getElementById('f_faculty').value.trim(),
                subject_specialization: document.getElementById('f_subject_specialization').value.trim(),
                personal_webpage: document.getElementById('f_personal_webpage').value.trim(),
                email: document.getElementById('f_email').value.trim(),
                phone: document.getElementById('f_phone').value.trim(),
                cell_phone: document.getElementById('f_cell_phone').value.trim(),
            };
            if (!body.full_name) { showToast('Name cannot be empty.', 'error'); return; }

            try {
                const res = await fetch('/api/teacher/profile', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body)
                });
                const data = await res.json();
                if (data.success) {
                    showToast('Profile updated successfully!', 'success');
                    toggleEdit();
                    // Soft-refresh hero without page reload
                    setTimeout(() => location.reload(), 800);
                } else {
                    showToast(data.msg || 'Update failed.', 'error');
                }
            } catch (e) {
                showToast('An error occurred.', 'error');
            }
        }

        // ── Upload Profile Picture ──
        async function uploadPicture(input) {
            if (!input.files || !input.files[0]) return;
            const formData = new FormData();
            formData.append('picture', input.files[0]);
            try {
                const res = await fetch('/api/teacher/profile/picture', {
                    method: 'POST',
                    body: formData
                });
                const data = await res.json();
                if (data.success) {
                    showToast('Profile picture updated!', 'success');
                    // Show new picture immediately
                    const url = `/static/uploads/teacher_pics/${data.filename}`;
                    const avatar = document.getElementById('avatarImg');
                    if (avatar.tagName === 'IMG') {
                        avatar.src = url;
                    } else {
                        // Replace div with img
                        const img = document.createElement('img');
                        img.id = 'avatarImg';
                        img.className = 'avatar-img';
                        img.src = url;
                        img.alt = 'Profile';
                        avatar.replaceWith(img);
                    }
                } else {
                    showToast(data.msg || 'Upload failed.', 'error');
                }
            } catch (e) {
                showToast('Upload error.', 'error');
            }
            input.value = '';
        }

        lucide.createIcons();

        // Dark Mode
        function toggleDarkMode() {
            const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
            const newTheme = isDark ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', newTheme);
            localStorage.setItem('teacher_theme', newTheme);
            updateDmIcon(newTheme);
        }
        function updateDmIcon(theme) {
            const icon = document.getElementById('dmIcon');
            if (!icon) return;
            icon.setAttribute('data-lucide', theme === 'dark' ? 'sun' : 'moon');
            lucide.createIcons();
        }
        updateDmIcon(localStorage.getItem('teacher_theme') || 'light');
    </script>
</body>

</html>


