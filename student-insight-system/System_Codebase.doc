st mb = document.querySelector('.mobile-toggle'); if (window.innerWidth <= 768 && sb?.classList.contains('active')) { if (!sb.contains(e.target) && !mb?.contains(e.target)) sb.classList.remove('active'); } });    /* ── Client-side navigation (no page blink) ─────────────────── */
    function syncStylesheets(doc) {
        // Sync <link rel="stylesheet">
        const curLinks = new Set(Array.from(document.querySelectorAll('link[rel="stylesheet"]')).map(l => l.getAttribute('href')?.split('?')[0]));
        doc.querySelectorAll('link[rel="stylesheet"]').forEach(nl => {
            const base = nl.getAttribute('href')?.split('?')[0];
            if (base && !curLinks.has(base)) {
                const lk = document.createElement('link');
                lk.rel = 'stylesheet';
                lk.href = nl.getAttribute('href');
                document.head.appendChild(lk);
            }
        });
        
        // Sync <style> blocks (matching by text content to avoid duplicates)
        const curStyles = new Set(Array.from(document.querySelectorAll('style')).map(s => s.textContent.trim()));
        doc.querySelectorAll('style').forEach(ns => {
            const content = ns.textContent.trim();
            if (content && !curStyles.has(content)) {
                const styleEl = document.createElement('style');
                styleEl.textContent = content;
                document.head.appendChild(styleEl);
                curStyles.add(content);
            }
        });

        // Sync <script src> from <head> (e.g. ui_alerts.js)
        const curScripts = new Set(Array.from(document.querySelectorAll('script[src]')).map(s => s.getAttribute('src')?.split('?')[0]));
        doc.querySelectorAll('head script[src]').forEach(ns => {
            const base = ns.getAttribute('src')?.split('?')[0];
            if (base && !curScripts.has(base)) {
                const sc = document.createElement('script');
                sc.src = ns.getAttribute('src');
                document.head.appendChild(sc);
                curScripts.add(base);
            }
        });
    } document.addEventListener('click', e => { const link = e.target.closest('a.nav-link'); if (!link || link.classList.contains('logout-link')) return; e.preventDefault(); const url = link.href; document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active')); link.classList.add('active'); fetch(url, { redirect: 'follow' }).then(r => { if (r.redirected) { const dest = r.url.toLowerCase(); if (dest.endsWith('/') || dest.includes('#auth') || dest.includes('/logout') || dest.includes('/login')) { window.location.href = r.url; return null; } } if (r.status === 401 || r.status === 403) { window.location.href = '/logout'; return null; } if (!r.ok) { window.location.href = url; return null; } return r.text(); }).then(html => { if (!html) return; const doc = new DOMParser().parseFromString(html, 'text/html'); const nmc = doc.querySelector('.main-content'); const omc = document.querySelector('.main-content'); if (!nmc || !omc) { window.location.href = url; return; } syncStylesheets(doc); omc.innerHTML = nmc.innerHTML; omc.querySelectorAll('script').forEach(os => { const ns = document.createElement('script');[...os.attributes].forEach(a => ns.setAttribute(a.name, a.value)); ns.textContent = os.textContent; os.parentNode.replaceChild(ns, os); }); const nt = doc.querySelector('title'); if (nt) document.title = nt.textContent; history.pushState({}, '', url); window.scrollTo(0, 0); if (typeof initStudentDashboardCharts === 'function') initStudentDashboardCharts(); }).catch(() => window.location.href = url); }); window.addEventListener('popstate', () => location.reload()); function logout() { window.location.href = "{{ url_for('auth.logout') }}"; }</script>


