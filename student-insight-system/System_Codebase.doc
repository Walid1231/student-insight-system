FILE: templates\teacher_dashboard.html
================================================================================

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Teacher Dashboard | Student Insight</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- defer: downloads in parallel, executes after HTML parse, before DOMContentLoaded -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js" defer></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="{{ url_for('static', filename='css/dashboard.css') }}" rel="stylesheet">
    <!-- Anti-flicker: apply saved theme before first paint -->
    <script>if(localStorage.getItem('teacher_theme')==='dark')document.documentElement.setAttribute('data-theme','dark');</script>

    <link href="{{ url_for('static', filename='css/ui_alerts.css') }}" rel="stylesheet">
    <script src="{{ url_for('static', filename='js/ui_alerts.js') }}"></script>
</head>

<body>
    <!-- Sidebar Toggle Button -->
    <button class="sidebar-toggle" onclick="toggleSidebar()" aria-label="Toggle Sidebar" id="sidebarToggle">
        <i data-lucide="menu"></i>
    </button>
    <!-- Mobile Backdrop -->
    <div id="sidebarBackdrop" onclick="closeSidebar()"
        style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:1999;"></div>


    <nav class="sidebar">
        <div class="logo">Teacher Dashboard</div>
        <div class="nav-links">
            <a href="/teacher/dashboard" class="nav-item active">
                <span class="nav-icon"><i data-lucide="layout-dashboard"></i></span> Dashboard
            </a>
            <a href="/teacher/students" class="nav-item">
                <span class="nav-icon"><i data-lucide="users"></i></span> Students
            </a>
            <a href="/teacher/alerts" class="nav-item">
                <span class="nav-icon"><i data-lucide="bell"></i></span> Alerts
                {% if overview.alerts_count > 0 %}
                <span
                    style="margin-left:auto; background:var(--danger); color:white; padding:2px 6px; border-radius:10px; font-size:10px;">{{
                    overview.alerts_count }}</span>
                {% endif %}
            </a>
            <a href="/teacher/notes" class="nav-item">
                <span class="nav-icon"><i data-lucide="file-text"></i></span> My Notes
            </a>
            <a href="/teacher/profile" class="nav-item">
                <span class="nav-icon"><i data-lucide="user"></i></span> My Profile
            </a>
        </div>
        <div class="sidebar-footer">
            <a href="/logout" class="nav-item" style="color: var(--danger);">
                <span class="nav-icon"><i data-lucide="log-out"></i></span> Logout
            </a>
        </div>
    </nav>

    <div class="main-content">
        <div class="header">
            <div>
                <h1>Hello, {{ teacher.full_name }}</h1>
                <p style="color:var(--gray-500)">Here's what's happening in your classes today.</p>
            </div>
            <div style="display:flex; align-items:center; gap:12px; font-size:14px; color:var(--gray-500)">
                {{ now_date }}
                <button class="dm-toggle" id="dmToggle" onclick="toggleDarkMode()" title="Toggle dark mode">
                    <i data-lucide="moon" id="dmIcon"></i>
                </button>
            </div>
        </div>

        <!-- KPI Cards -->
        <div class="grid">
            <div class="card stat-card">
                <div class="stat-info">
                    <div class="value">{{ overview.total_students }}</div>
                    <div class="label">Total Students</div>
                </div>
                <div class="stat-icon orange"><i data-lucide="users"></i></div>
            </div>

            <div class="card stat-card">
                <div class="stat-info">
                    <div class="value">{{ overview.at_risk_count }}</div>
                    <div class="label">At Risk</div>
                </div>
                <div class="stat-icon" style="background:#fee2e2;"><i data-lucide="alert-triangle"
                        style="color:var(--danger);"></i></div>
            </div>

            <div class="card stat-card">
                <div class="stat-info">
                    <div class="value">{{ overview.average_percent }}%</div>
                    <div class="label">Avg Performance</div>
                </div>
                <div class="stat-icon" style="background:#d1fae5;"><i data-lucide="trending-up"
                        style="color:var(--success);"></i></div>
            </div>

            <div class="card stat-card">
                <div class="stat-info">
                    <div class="value">{{ overview.alerts_count }}</div>
                    <div class="label">Active Alerts</div>
                </div>
                <div class="stat-icon" style="background:#fef3c7;"><i data-lucide="bell"
                        style="color:var(--warning);"></i></div>
            </div>
        </div>

        <!-- Charts + Alerts: Performance spans full width; Heatmap & Alerts share the row below -->
        <div class="dash-section-grid">

            <!-- Row 1: Performance Distribution (full width) -->
            <div class="card dash-area-chart">
                <h3>Performance Distribution</h3>
                <div class="chart-container">
                    <canvas id="performanceChart"></canvas>
                </div>
            </div>

            <!-- Row 2, Left: Risk Heatmap -->
            <div class="card dash-area-heatmap">
                <h3>Class Skill Risk Heatmap</h3>
                <div id="heatmapContainer" style="overflow-x:auto; margin-top:12px; max-height:260px;">
                    <div style="text-align:center; color:var(--text-secondary);">Loading Risk Data...</div>
                </div>
            </div>

            <!-- Row 2, Right: Alerts Panel -->
            <div class="card dash-area-alerts">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:14px;">
                    <h3 style="margin:0;">Recent Alerts</h3>
                    <a href="/teacher/alerts" style="font-size:12px; color:var(--primary);">View All</a>
                </div>

                <div class="alerts-list">
                    {% for alert in alerts[:5] %}
                    <div class="alert-item" id="alert-{{ alert.id }}">
                        <div style="min-width:0; flex:1;">
                            <div style="font-size:13px; font-weight:600; white-space:normal;">{{ alert.message }}</div>
                            <div style="font-size:11px; color:var(--text-secondary); margin-top:2px;">
                                {{ alert.student.full_name }} • {{ alert.created_at.strftime('%Y-%m-%d') }}
                            </div>
                        </div>
                        <div style="display:flex; gap:6px; align-items:center; flex-shrink:0;">
                            <span class="alert-badge {{ alert.severity }}">{{ alert.severity }}</span>
                            <button class="btn-sm" onclick="resolveAlert({{ alert.id }})">
                                <i data-lucide="check" style="width:13px; height:13px;"></i>
                            </button>
                        </div>
                    </div>
                    {% else %}
                    <div style="color:var(--text-secondary); text-align:center; padding:20px;">No active alerts</div>
                    {% endfor %}
                </div>
            </div>

        </div>

    </div>

    <script>
        // Sidebar Toggle — viewport-aware
        // Desktop (>768px): collapses to icon-only rail (.collapsed + .expanded)
        // Mobile  (≤768px): slides in as full overlay (.open + backdrop)
        function toggleSidebar() {
            const isMobile = window.innerWidth <= 768;
            const sidebar = document.querySelector('nav.sidebar');
            const backdrop = document.getElementById('sidebarBackdrop');

            if (isMobile) {
                const isOpen = sidebar.classList.toggle('open');
                if (backdrop) backdrop.style.display = isOpen ? 'block' : 'none';
            } else {
                const mainContent = document.querySelector('.main-content');
                const isCollapsed = sidebar.classList.toggle('collapsed');
                // Sync body class so `body.sidebar-collapsed button.sidebar-toggle`
                // CSS rule fires and the hamburger slides in sync with the sidebar
                document.body.classList.toggle('sidebar-collapsed', isCollapsed);
                if (mainContent) mainContent.classList.toggle('expanded', isCollapsed);
                localStorage.setItem('sidebarCollapsed', isCollapsed);
            }
        }

        function closeSidebar() {
            const sidebar = document.querySelector('nav.sidebar');
            const backdrop = document.getElementById('sidebarBackdrop');
            if (sidebar) { sidebar.classList.remove('open'); }
            if (backdrop) { backdrop.style.display = 'none'; }
        }

        // Restore desktop collapsed state on page load (mobile ignores this)
        window.addEventListener('DOMContentLoaded', () => {
            if (window.innerWidth > 768) {
                const isCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';
                if (isCollapsed) {
                    const sidebar = document.querySelector('nav.sidebar');
                    const mainContent = document.querySelector('.main-content');
                    if (sidebar) sidebar.classList.add('collapsed');
                    if (mainContent) mainContent.classList.add('expanded');
                    // Restore hamburger position too
                    document.body.classList.add('sidebar-collapsed');
                }
            }
        });

        // ── DOMContentLoaded guard: Chart.js (deferred) is guaranteed ready here ──
        document.addEventListener('DOMContentLoaded', function () {
            if (typeof Chart === 'undefined') {
                console.warn('[Dashboard] Chart.js failed to load — skipping chart init');
                return;
            }
            // Safe Jinja → JS bridge: | default(0) | int prevents None/null in array literal
            var ctxEl = document.getElementById('performanceChart');
            if (!ctxEl) return;
            new Chart(ctxEl.getContext('2d'), {
                type: 'doughnut',
                data: {
                    labels: ['Good', 'Average', 'At Risk'],
                    datasets: [{
                        data: [
                            {{ overview.good_count | default(0) | int }},
                            {{ overview.average_count | default(0) | int }},
            {{ overview.at_risk_count | default(0) | int }}
                        ],
            backgroundColor: [
            'rgba(16, 185, 129, 0.8)',
            'rgba(245, 158, 11, 0.8)',
            'rgba(239, 68, 68, 0.8)'
        ],
            borderColor: [
            'rgba(16, 185, 129, 1)',
            'rgba(245, 158, 11, 1)',
            'rgba(239, 68, 68, 1)'
        ],
            borderWidth: 2
                    }]
                },
            options: {
            responsive: true,
            maintainAspectRatio: false,
            cutout: '70%',
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: {
                        color: 'rgba(255, 255, 255, 0.9)',
                        font: { size: 13, weight: '600' },
                        padding: 15
                    }
                }
            }
        }
            });
        }); // end DOMContentLoaded


        // Resolve Alert Function
        async function resolveAlert(alertId) {
            showConfirm("Resolve Warning?", "Mark this academic alert as resolved?", async () => {
                try {
                    const response = await fetch(`/api/teacher/alerts/${alertId}/resolve`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' }
                    });

                    if (response.ok) {
                        const el = document.getElementById(`alert-${alertId}`);
                        if (el) el.remove();
                        showToast("Alert resolved successfully.", "success");
                    } else {
                        showToast("Failed to resolve alert.", "error");
                    }
                } catch (error) {
                    console.error("Error:", error);
                    showToast("An error occurred.", "error");
                }
            }, "Resolve");
        }

        // LOAD HEATMAP
        async function loadHeatmap() {
            try {
                const res = await fetch('/api/teacher/class-skills');
                const data = await res.json();

                if (data.length === 0) {
                    document.getElementById('heatmapContainer').innerHTML = "No skill data available.";
                    return;
                }

                // 1. Collect all unique skills
                const allSkills = new Set();
                data.forEach(s => s.skills.forEach(sk => allSkills.add(sk.name)));
                const skillList = Array.from(allSkills);

                // 2. Build Table
                let html = `<table style="width:100%; border-collapse:collapse; font-size:12px;">`;

                // Header
                html += `<thead><tr><th style="text-align:left; padding:8px;">Student</th>`;
                skillList.forEach(sk => html += `<th style="padding:8px; text-align:center;">${sk}</th>`);
                html += `</tr></thead><tbody>`;

                // Rows
                data.forEach(s => {
                    html += `<tr><td style="padding:8px; border-bottom:1px solid #eee; font-weight:600;">${s.name}</td>`;

                    skillList.forEach(headerskill => {
                        const studentSkill = s.skills.find(sk => sk.name === headerskill);
                        if (studentSkill) {
                            // Color based on risk (0.0 - 1.0)
                            // Low Risk (Green) -> High Risk (Red)
                            // Risk > 0.7 = Red, > 0.4 = Yellow, Else Green
                            let color = '#d1fae5'; // Green
                            if (studentSkill.risk > 0.7) color = '#fee2e2'; // Red
                            else if (studentSkill.risk > 0.4) color = '#fef3c7'; // Yellow

                            html += `<td style="padding:8px; border-bottom:1px solid #eee; text-align:center; background:${color}; color:#333;">
                                ${studentSkill.score}%
                                </td>`;
                        } else {
                            html += `<td style="padding:8px; border-bottom:1px solid #eee; text-align:center; color:#ccc;">--</td>`;
                        }
                    });

                    html += `</tr>`;
                });

                html += `</tbody></table>`;
                document.getElementById('heatmapContainer').innerHTML = html;

            } catch (e) {
                console.error("Heatmap Error:", e);
                document.getElementById('heatmapContainer').innerHTML = "Error loading data.";
            }
        }

        loadHeatmap();

        // Initialize Lucide icons
        lucide.createIcons();

        // Dark Mode
        function toggleDarkMode() {
            const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
            const newTheme = isDark ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', newTheme);
            localStorage.setItem('teacher_theme', newTheme);
            updateDmIcon(newTheme);
        }
        function updateDmIcon(theme) {
            const icon = document.getElementById('dmIcon');
            if (!icon) return;
            icon.setAttribute('data-lucide', theme === 'dark' ? 'sun' : 'moon');
            lucide.createIcons();
        }
        // Apply icon on load
        updateDmIcon(localStorage.getItem('teacher_theme') || 'light');

        // ─────────────────────────────────────────────────────────

        // Close sidebar on resize to desktop viewport
        window.addEventListener('resize', () => {
            if (window.innerWidth > 768) {
                // On desktop resize: close mobile overlay-style open, keep collapsed state
                const sidebar = document.querySelector('nav.sidebar');
                if (sidebar) sidebar.classList.remove('open');
                const backdrop = document.getElementById('sidebarBackdrop');
                if (backdrop) backdrop.style.display = 'none';
            }
        });
        // ─────────────────────────────────────────────────────────

    </script>
</body>

</html>


