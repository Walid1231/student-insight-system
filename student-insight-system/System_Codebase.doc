<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Goals &amp; Grades | Student Insight</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Set career goals, track skills, and manage academic grades.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/unified_styles.css') }}?v=3">
    <style>
        :root {
            --navy: #0f172a;
            --gold: #f59e0b;
            --brand: var(--navy);
            --bg: #f8fafc;
            --card-bg: #ffffff;
            --border: #e2e8f0;
            --text: #1e293b;
            --muted: #64748b;
            --green: #10b981;
            --red: #ef4444;
        }

        body {
            background: var(--bg);
            font-family: 'Inter', sans-serif;
        }

        h1,
        h2,
        h3 {
            font-family: 'Inter', sans-serif;
            font-weight: 700;
        }

        .gg-layout {
            display: flex;
            flex-direction: column;
            gap: 28px;
        }

        /* ── Wizard Cards ── */
        .gg-card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 14px;
            box-shadow: 0 2px 16px rgba(0, 0, 0, .06);
            position: relative;
            overflow: hidden;
        }

        .gg-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--navy), var(--gold));
        }

        .gg-card-header {
            padding: 22px 28px 16px;
            border-bottom: 1px solid var(--border);
        }

        .gg-card-header h2 {
            font-size: 21px;
            color: var(--navy);
            margin: 0 0 4px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .gg-card-header h2 i {
            font-size: 17px;
            opacity: .8;
        }

        .gg-card-header p {
            font-size: 13px;
            color: var(--muted);
            margin: 0;
        }

        .gg-card-body {
            padding: 24px 28px;
        }

        #card-goals .gg-card-body {
            max-height: 650px;
            overflow-y: auto;
            padding-right: 15px;
        }

        #card-goals .gg-card-body::-webkit-scrollbar {
            width: 6px;
        }

        #card-goals .gg-card-body::-webkit-scrollbar-track {
            background: transparent;
        }

        #card-goals .gg-card-body::-webkit-scrollbar-thumb {
            background-color: #cbd5e1;
            border-radius: 10px;
        }

        /* ── Animated collapse ── */
        .gg-collapsible {
            max-height: 0;
            opacity: 0;
            overflow: hidden;
            transform: translateY(8px);
            transition: max-height .4s ease, opacity .35s ease, transform .35s ease;
        }

        .gg-collapsible.card-visible {
            max-height: 1200px;
            opacity: 1;
            transform: translateY(0);
        }

        /* ── Dept display ── */
        .dept-wrap {
            display: flex;
            align-items: center;
            gap: 14px;
            background: var(--bg);
            padding: 14px 18px;
            border-radius: 10px;
            border: 1px solid var(--border);
        }

        .dept-wrap>i {
            color: var(--brand);
            font-size: 22px;
            flex-shrink: 0;
        }

        /* ── Chips & pills ── */
        .pill-row {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 14px;
        }

        .s-chip {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 5px 13px;
            border-radius: 20px;
            border: 1.5px dashed #d1d5db;
            background: transparent;
            font-size: 12px;
            font-weight: 500;
            color: var(--muted);
            cursor: pointer;
            font-family: 'Inter', sans-serif;
            transition: all .15s;
        }

        .s-chip:hover:not(.s-added) {
            border-style: solid;
            border-color: var(--green);
            background: rgba(5, 150, 105, .08);
            color: var(--green);
        }

        .s-chip.s-added {
            border-style: solid;
            border-color: #d1d5db;
            background: #f3f4f6;
            color: #9ca3af;
            cursor: default;
        }

        .s-chip i {
            font-size: 9px;
        }

        .c-pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 13px;
            border-radius: 7px;
            border: 1.5px solid var(--border);
            background: var(--bg);
            font-size: 12px;
            font-weight: 500;
            color: var(--text);
            cursor: pointer;
            font-family: 'Inter', sans-serif;
            transition: border-color .15s, background .15s;
        }

        .c-pill:hover {
            border-color: var(--navy);
            background: rgba(0, 45, 98, .04);
        }

        .c-pill i {
            font-size: 10px;
            opacity: .6;
        }

        /* ── Skill tags ── */
        .skill-tags-area {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            min-height: 38px;
        }

        .sk-tag {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 7px 12px;
            border-radius: 7px;
            border: 1.5px solid rgba(0, 45, 98, .22);
            background: rgba(0, 45, 98, .05);
            font-size: 13px;
            font-weight: 500;
            color: var(--navy);
        }

        .sk-tag button {
            background: none;
            border: none;
            color: inherit;
            opacity: .5;
            cursor: pointer;
            padding: 0;
            font-size: 11px;
            line-height: 1;
            transition: opacity .15s;
        }

        .sk-tag button:hover {
            opacity: 1;
        }

        .skill-add-row {
            display: flex;
            gap: 8px;
            margin-top: 14px;
        }

        .skill-add-row input {
            flex: 1;
        }

        /* ── Suggest label ── */
        .suggest-label {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .5px;
            color: var(--muted);
            margin-top: 22px;
            margin-bottom: 6px;
            display: flex;
            align-items: center;
            gap: 7px;
        }

        .suggest-label i {
            color: var(--navy);
        }

        /* ── Target CGPA strip ── */
        .target-strip {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
            padding: 12px 16px;
            border-radius: 9px;
            background: var(--bg);
            border: 1px solid var(--border);
            margin-bottom: 22px;
        }

        .target-strip label {
            font-size: 13px;
            font-weight: 600;
            color: var(--text);
            white-space: nowrap;
        }

        .target-strip input {
            width: 90px;
        }

        #cgpa-save-status {
            font-size: 12px;
            color: var(--green);
            font-weight: 500;
            opacity: 0;
            transition: opacity .3s;
        }

        .target-strip .cur {
            font-size: 12px;
            color: var(--muted);
            margin-left: auto;
        }

        .target-strip .cur strong {
            color: var(--navy);
            font-size: 14px;
        }

        /* ── Dropdown for Matches ── */
        .matches-dropdown {
            margin-bottom: 24px;
            border: 1px solid var(--border);
            border-radius: 10px;
            background: #fff;
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .matches-dropdown-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 16px;
            background: #f8fafc;
            cursor: pointer;
            user-select: none;
            transition: background 0.2s;
        }

        .matches-dropdown-header:hover {
            background: #f1f5f9;
        }

        .matches-dropdown-header .label-content {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .5px;
            color: var(--muted);
        }

        .matches-dropdown-header i.fa-chevron-down {
            font-size: 11px;
            transition: transform 0.3s ease;
            color: var(--muted);
        }

        .matches-dropdown.is-active .fa-chevron-down {
            transform: rotate(180deg);
        }

        .matches-dropdown-body {
            max-height: 0;
            opacity: 0;
            overflow: hidden;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .matches-dropdown.is-active .matches-dropdown-body {
            max-height: 800px;
            opacity: 1;
            padding: 15px;
            overflow-y: auto;
        }

        /* ── Career Cards Grid ── */
        .goal-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
            margin-top: 10px;
        }

        .goal-card {
            background: var(--card-bg);
            border: 1.5px solid var(--border);
            border-radius: 12px;
            padding: 18px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            transition: all 0.2s ease;
            position: relative;
            background: #fff;
        }

        .goal-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.08);
            border-color: var(--navy);
        }

        .goal-card.is-primary {
            border-color: var(--navy);
            background: rgba(15, 23, 42, 0.02);
        }

        .goal-card.is-primary::after {
            content: 'PRIMARY';
            position: absolute;
            top: -10px;
            right: 15px;
            background: var(--navy);
            color: #fff;
            font-size: 9px;
            font-weight: 800;
            padding: 2px 8px;
            border-radius: 10px;
            letter-spacing: 0.5px;
        }

        .goal-card-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 10px;
        }

        .goal-card-header h4 {
            margin: 0;
            font-size: 15px;
            font-weight: 700;
            color: var(--navy);
            line-height: 1.3;
        }

        .goal-card-type {
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            color: var(--muted);
            background: var(--bg);
            padding: 2px 6px;
            border-radius: 4px;
            white-space: nowrap;
        }

        .goal-card-body {
            font-size: 13px;
            color: var(--text);
            max-height: 160px; /* Standardized height */
            overflow-y: auto;
            padding-right: 10px;
            margin: 8px 0;
            border-bottom: 1px solid transparent;
            transition: border-color 0.2s;
        }

        .goal-card:hover .goal-card-body {
            border-bottom-color: #f1f5f9;
        }

        .sk-list {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            margin-top: 10px;
        }

        .sk-pill {
            font-size: 11px;
            padding: 2px 8px;
            border-radius: 12px;
            background: #f1f5f9;
            color: #64748b;
            border: 1px solid #e2e8f0;
        }

        .sk-pill.matched {
            background: #dcfce7;
            color: #166534;
            border-color: #bbf7d0;
        }

        /* Custom Scrollbar for Card Body */
        .goal-card-body::-webkit-scrollbar {
            width: 4px;
        }
        .goal-card-body::-webkit-scrollbar-track {
            background: transparent;
        }
        .goal-card-body::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 10px;
        }

        .match-stat {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 8px;
        }

        .match-score {
            font-size: 12px;
            font-weight: 700;
            color: var(--navy);
        }

        .match-bar-bg {
            height: 6px;
            background: #e2e8f0;
            border-radius: 3px;
            overflow: hidden;
            margin-bottom: 12px;
        }

        .match-bar-fill {
            height: 100%;
            background: var(--navy);
            border-radius: 3px;
            transition: width 0.4s ease;
        }

        .goal-card-footer {
            margin-top: auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-top: 12px;
            border-top: 1px solid var(--border);
        }

        /* ── Compact Variant ── */
        .goal-card.compact {
            padding: 12px 14px;
            gap: 8px;
        }

        .goal-card.compact .goal-card-header h4 {
            font-size: 14px;
        }

        .goal-card.compact .goal-card-body {
            max-height: 100px; /* More compact viewport */
            margin: 4px 0;
            padding-right: 8px;
        }

        .goal-card.compact .sk-pill {
            font-size: 10px;
            padding: 1px 6px;
        }

        .goal-card.compact .goal-card-footer {
            padding-top: 8px;
        }

        .btn-card-action {
            padding: 6px 12px;
            font-size: 12px;
            font-weight: 600;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.15s;
            font-family: inherit;
        }

        .btn-set-primary {
            background: transparent;
            border: 1.5px solid var(--navy);
            color: var(--navy);
        }

        .btn-set-primary:hover {
            background: var(--navy);
            color: #fff;
        }

        .btn-delete-goal {
            background: transparent;
            border: none;
            color: var(--muted);
            padding: 6px;
        }

        .btn-delete-goal:hover {
            color: var(--red);
            background: rgba(239, 68, 68, 0.05);
        }

        .btn-del {
            background: none;
            border: none;
            color: var(--muted);
            cursor: pointer;
            font-size: 13px;
            padding: 4px 8px;
            border-radius: 6px;
            transition: all .15s;
        }

        .btn-del:hover {
            color: var(--red);
            background: rgba(220, 38, 38, .07);
        }

        /* ── Grade form ── */
        .grade-grid {
            display: grid;
            grid-template-columns: 2fr 1fr 80px 1fr 1fr auto;
            gap: 12px;
            align-items: end;
        }

        @media (max-width: 800px) {
            .grade-grid {
                grid-template-columns: 1fr 1fr;
            }
        }

        .fg label {
            display: block;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .4px;
            color: var(--muted);
            margin-bottom: 6px;
        }

        /* ── CGPA chip ── */
        .cgpa-chip {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 5px 14px;
            border-radius: 7px;
            background: rgba(5, 150, 105, .1);
            color: var(--green);
            font-size: 13px;
            font-weight: 700;
        }

        /* ── Type badges ── */
        .type-badge {
            display: inline-block;
            font-size: 11px;
            font-weight: 600;
            padding: 3px 9px;
            border-radius: 5px;
        }

        .type-core {
            background: rgba(0, 45, 98, .1);
            color: var(--navy);
        }

        .type-ged {
            background: rgba(5, 150, 105, .1);
            color: var(--green);
        }

        .type-elective {
            background: rgba(124, 58, 237, .1);
            color: #7c3aed;
        }

        /* ── Empty state ── */
        .gg-empty {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
            padding: 36px 16px;
            color: var(--muted);
            text-align: center;
        }

        .gg-empty i {
            font-size: 28px;
            opacity: .35;
        }

        .gg-empty p {
            font-size: 13px;
            margin: 0;
        }

        /* ── Academic Record Table ── */
        .mini-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            font-size: 13px;
        }

        .mini-table thead th {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .5px;
            color: var(--muted);
            padding: 14px 14px 10px;
            border-bottom: 2px solid var(--border);
            text-align: left;
            white-space: nowrap;
            background: var(--bg);
        }

        .mini-table thead th:first-child {
            border-radius: 10px 0 0 0;
        }

        .mini-table thead th:last-child {
            border-radius: 0 10px 0 0;
        }

        .mini-table tbody td {
            padding: 12px 14px;
            color: var(--text);
            border-bottom: 1px solid #f1f5f9;
            vertical-align: middle;
            transition: background .15s;
        }

        .mini-table tbody tr:last-child td {
            border-bottom: none;
        }

        .mini-table tbody tr:nth-child(even) td {
            background: rgba(248, 250, 252, .5);
        }

        .mini-table tbody tr:hover td {
            background: rgba(15, 23, 42, .03);
        }

        .mini-table tbody td:first-child {
            font-weight: 600;
            color: var(--navy);
        }

        .mini-table tbody td strong {
            font-weight: 700;
            color: var(--navy);
        }

        .records-scroll-wrap {
            overflow-x: auto;
            border-radius: 10px;
            border: 1px solid var(--border);
        }

        .records-scroll-wrap::-webkit-scrollbar {
            height: 6px;
        }

        .records-scroll-wrap::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 10px;
        }

        /* ── Toast ── */
        #gg-toast {
            position: fixed;
            bottom: 28px;
            right: 28px;
            background: var(--navy);
            color: #fff;
            padding: 13px 20px;
            border-radius: 10px;
            box-shadow: 0 8px 24px rgba(0, 0, 0, .18);
            font-size: 14px;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 10px;
            opacity: 0;
            transform: translateY(10px);
            transition: opacity .25s, transform .25s;
            z-index: 9999;
            pointer-events: none;
            font-family: 'DM Sans', sans-serif;
        }

        #gg-toast.show {
            opacity: 1;
            transform: translateY(0);
        }

        #gg-toast.err {
            background: var(--red);
        }

        /* ── Spinner ── */
        .spin {
            display: inline-block;
            animation: spin .6s linear infinite;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        /* ── Step indicator ── */
        .step-number {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 26px;
            height: 26px;
            border-radius: 50%;
            background: var(--navy);
            color: #fff;
            font-size: 12px;
            font-weight: 700;
            font-family: 'Inter', sans-serif;
            flex-shrink: 0;
        }

        /* scrollbar flash on card reveal */
        @keyframes highlightCard {
            0% {
                box-shadow: 0 0 0 3px rgba(201, 168, 76, .45), 0 2px 16px rgba(0, 0, 0, .06);
            }

            100% {
                box-shadow: 0 2px 16px rgba(0, 0, 0, .06);
            }
        }

        .card-flash {
            animation: highlightCard .9s ease forwards;
        }

        /* dark mode */
        html[data-theme="dark"] .gg-card {
            background: #1a1d27;
            border-color: #2d3241;
        }

        html[data-theme="dark"] .gg-card-header {
            border-color: #2d3241;
        }

        html[data-theme="dark"] .gg-card-header h2 {
            color: #93c5fd;
        }

        html[data-theme="dark"] .target-strip {
            background: #141720;
            border-color: #2d3241;
        }

        html[data-theme="dark"] .career-row {
            background: #141720;
            border-color: #2d3241;
        }

        html[data-theme="dark"] .career-row h4 {
            color: #e5e7eb;
        }

        html[data-theme="dark"] .sk-tag {
            border-color: rgba(107, 158, 222, .35);
            background: rgba(107, 158, 222, .1);
            color: #6b9fde;
        }

        html[data-theme="dark"] .mini-table thead th {
            background: #141720;
            border-color: #2d3241;
            color: #9ca3af;
        }

        html[data-theme="dark"] .mini-table tbody td {
            border-color: #2d3241;
            color: #d1d5db;
        }

        html[data-theme="dark"] .mini-table tbody tr:nth-child(even) td {
            background: rgba(20, 23, 32, .5);
        }

        html[data-theme="dark"] .mini-table tbody tr:hover td {
            background: #1e2231;
        }

        html[data-theme="dark"] .records-scroll-wrap {
            border-color: #2d3241;
        }

        html[data-theme="dark"] .c-pill {
            background: #141720;
            border-color: #2d3241;
            color: #d1d5db;
        }

        html[data-theme="dark"] .gg-sep {
            border-color: #2d3241;
        }
    </style>
</head>

<body>
    {% set active_page = 'goals' %}
    {% include 'components/sidebar.html' %}

    <main class="main-content">
        <div class="dashboard-container">

            <div class="welcome-header" style="margin-bottom:28px;">
                <h1
                    style="font-family:'Inter',sans-serif;font-weight:800;color:var(--navy);font-size:30px;margin:0 0 6px;display:flex;align-items:center;gap:12px;">
                    <i class="fas fa-bullseye" style="font-size:24px;color:var(--gold);"></i> Goals &amp; Grades
                </h1>
                <p style="font-size:14px;color:var(--muted);margin:0;">Your department drives your career and skill
                    suggestions below.</p>
            </div>

            <div class="gg-layout">

                <!-- ══ STEP 0 · Department (auto-loaded from profile) ══ -->
                <div class="gg-card" id="card-dept">
                    <div class="gg-card-header">
                        <h2><span class="step-number">1</span><i class="fas fa-university"></i> Department</h2>
                        <p>Loaded from your profile — skills and career paths appear automatically</p>
                    </div>
                    <div class="gg-card-body">
                        <div class="dept-wrap">
                            <i class="fas fa-graduation-cap"></i>
                            <select id="dept-select" class="form-input" disabled
                                style="background:#f9fafb; cursor:not-allowed;">
                                <option value="">— Please configure your Department in your Profile —</option>
                                {% for group_name, depts in dept_groups %}
                                <optgroup label="{{ group_name }}">
                                    {% for dept in depts %}
                                    <option value="{{ dept }}" {% if student.department==dept %}selected{% endif %}>{{
                                        dept }}</option>
                                    {% endfor %}
                                </optgroup>
                                {% endfor %}
                            </select>
                        </div>
                        {% if not student.department %}
                        <div style="margin-top: 12px;">
                            <a href="{{ url_for('dashboard.student_profile') }}" class="btn-add-g"
                                style="text-decoration:none; display:inline-flex; align-items:center; gap:6px; color:#fff; background:var(--navy); padding:6px 12px; border-radius:6px; font-size:13px; font-weight:600;">
                                <i class="fas fa-user-edit"></i> Edit Profile to unlock
                            </a>
                        </div>
                        {% else %}
                        <div
                            style="margin-top: 8px; font-size: 11px; text-transform: uppercase; font-weight: 700; color: var(--muted); letter-spacing: 0.5px;">
                            <i class="fas fa-lock" style="margin-right:4px;"></i> Synced from Profile
                        </div>
                        {% endif %}


                        <div id="dept-careers-wrap" style="display:none;">
                            <div class="suggest-label"><i class="fas fa-briefcase"></i> Suggested Career Paths</div>
                            <div class="pill-row" id="career-pills"></div>
                        </div>
                    </div>
                </div>

                <!-- ══ STEP 1 · Skills ══ -->
                <div class="gg-card gg-collapsible" id="card-skills">
                    <div class="gg-card-header">
                        <h2><span class="step-number">2</span><i class="fas fa-layer-group"></i> Your Skills</h2>
                        <p>Skills power your career matches — add from suggestions or type your own</p>
                    </div>
                    <div class="gg-card-body">

                        <div id="dept-skills-wrap" style="display:none;">
                            <div class="suggest-label"><i class="fas fa-tools"></i> Suggested for your department —
                                click to add</div>
                            <div class="pill-row" id="skill-pills"></div>
                            <hr class="gg-sep">
                        </div>

                        <div class="suggest-label" style="margin-top:0;"><i class="fas fa-check-circle"
                                style="color:var(--green);"></i> Your Current Skills</div>
                        <div class="skill-tags-area" id="skill-tags-area">
                            {% for ss in student_skills %}
                            <div class="sk-tag" data-skill-id="{{ ss.id }}">
                                <i class="fas fa-check" style="font-size:9px;"></i>
                                {{ ss.skill_name }}
                                <button onclick="deleteSkill({{ ss.id }}, this)" title="Remove"><i
                                        class="fas fa-times"></i></button>
                            </div>
                            {% else %}
                            <div class="gg-empty" id="no-skills-msg" style="padding:10px 0;">
                                <p>No skills yet — pick from suggestions or type below.</p>
                            </div>
                            {% endfor %}
                        </div>

                        <div class="skill-add-row">
                            <input type="text" id="skill-input" class="form-input" list="master-skills-list"
                                placeholder="e.g. Python, Machine Learning, Public Speaking…" autocomplete="off">
                            <datalist id="master-skills-list">
                                {% for s in all_skills %}
                                <option value="{{ s.skill_name }}">
                                {% endfor %}
                            </datalist>
                            <button id="add-skill-btn" class="btn btn-primary" onclick="addSkill()"
                                style="white-space:nowrap;padding:10px 20px;">
                                <i class="fas fa-plus"></i> Add Skill
                            </button>
                        </div>
                    </div>
                </div>

                <!-- ══ STEP 2 · Career Goals ══ -->
                <div class="gg-card gg-collapsible" id="card-goals">
                    <div class="gg-card-header">
                        <h2><span class="step-number">3</span><i class="fas fa-star"></i> Career Goals</h2>
                        <p>Set your target CGPA and choose career paths you're working towards</p>
                    </div>
                    <div class="gg-card-body">

                        <div class="target-strip">
                            <i class="fas fa-trophy" style="color:var(--gold);font-size:16px;"></i>
                            <label>Target CGPA</label>
                            <input type="number" id="target-cgpa-input" class="form-input" step="0.01" min="0" max="4.0"
                                value="{{ student.target_cgpa or '' }}" placeholder="e.g. 3.50"
                                onkeydown="if(event.key==='Enter'){event.preventDefault();saveTargetCgpa();}">
                            <button id="cgpa-save-btn" class="btn btn-primary" onclick="saveTargetCgpa()"
                                style="padding:8px 16px;font-size:12px;">
                                <i class="fas fa-save"></i> Save
                            </button>
                            <span id="cgpa-save-status"><i class="fas fa-check"></i> Saved</span>
                            <span class="cur">Current: <strong id="live-cgpa">{{ student.current_cgpa or 'N/A'
                                    }}</strong></span>
                        </div>

                        <div class="sub-label"><i class="fas fa-search"></i> Select Career Goal Manually</div>
                        <div class="skill-add-row" style="margin-bottom:28px;gap:10px;">
                            <select id="manual-career-select" class="form-input" style="flex:2;">
                                <option value="">— Choose a career path —</option>
                                {% for c in all_careers %}
                                <option value="{{ c.id }}">{{ c.title }}</option>
                                {% endfor %}
                            </select>
                            <select id="manual-goal-type" class="form-input" style="flex:1;">
                                <option value="Long Term">Long Term</option>
                                <option value="Short Term">Short Term</option>
                            </select>
                            <button id="add-manual-goal-btn" class="btn btn-primary" onclick="addManualGoal()"
                                style="white-space:nowrap;padding:10px 20px;">
                                <i class="fas fa-plus"></i> Add Goal
                            </button>
                        </div>

                        <div class="matches-dropdown" id="matches-dropdown">
                            <div class="matches-dropdown-header" onclick="toggleMatches()">
                                <div class="label-content">
                                    <i class="fas fa-magic" style="color:var(--navy);"></i>
                                    Matches Based on Your Skills
                                </div>
                                <i class="fas fa-chevron-down"></i>
                            </div>
                            <div class="matches-dropdown-body">
                                <div id="matching-careers-area">
                                    {% if matching_careers %}
                                    <div class="goal-grid">
                                        {% for career in matching_careers %}
                                        <div class="goal-card" id="cr-{{ career.id }}">
                                            <div class="goal-card-header">
                                                <h4>{{ career.title }}</h4>
                                                <div class="career-actions">
                                                    {% if career.id not in goal_career_ids %}
                                                    <select class="goal-type-sel" id="gt-{{ career.id }}" style="padding: 2px 5px; height: 24px; font-size: 10px;">
                                                        <option value="Long Term">Long Term</option>
                                                        <option value="Short Term">Short Term</option>
                                                    </select>
                                                    {% endif %}
                                                </div>
                                            </div>
                                            <div class="goal-card-body">
                                                <div class="match-stat">
                                                    <span class="match-score">{{ career.match_count }} of {{ career.total_req }} skills</span>
                                                    {% set pct = (career.match_count / career.total_req * 100) | round | int if career.total_req > 0 else 0 %}
                                                    <span class="badge-added">{{ pct }}% MATCH</span>
                                                </div>
                                                <div class="match-bar-bg">
                                                    <div class="match-bar-fill" style="width: {{ pct }}%"></div>
                                                </div>
                                                
                                                <div class="sk-list">
                                                    {% for s in career.skills %}
                                                    <span class="sk-pill {% if s.matched %}matched{% endif %}">
                                                        {% if s.matched %}<i class="fas fa-check"></i> {% endif %}{{ s.name }}
                                                    </span>
                                                    {% endfor %}
                                                </div>
                                                
                                                <p style="margin-top:10px; margin-bottom:0; opacity:0.8; font-size:11px;">Field: {{ career.field_category or 'General' }}</p>
                                            </div>
                                            <div class="goal-card-footer" style="flex-wrap: wrap; gap: 8px;">
                                                {% if career.id not in goal_career_ids %}
                                                <button class="btn-card-action btn-set-primary" onclick="addAndSetPrimary({{ career.id }})" style="border-style: solid; background: var(--gold); color: #fff; border-color: var(--gold); flex: 1;">
                                                    <i class="fas fa-star"></i> Set as Primary Goal
                                                </button>
                                                <button class="btn-card-action btn-set-primary" onclick="addGoal({{ career.id }})" style="border-style: solid; flex: 1;">
                                                    <i class="fas fa-plus"></i> Add to Goals
                                                </button>
                                                {% else %}
                                                <span class="type-badge type-core"><i class="fas fa-check"></i> Already Saved</span>
                                                <button class="btn-delete-goal" onclick="deleteGoalByCareer({{ career.id }})">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                                {% endif %}
                                            </div>
                                        </div>
                                        {% endfor %}
                                    </div>
                                    {% else %}
                                    <div class="gg-empty">
                                        <i class="fas fa-search"></i>
                                        <p>Add skills above to see matching career paths here.</p>
                                    </div>
                                    {% endif %}
                                </div>
                            </div>
                        </div>

                        <!-- Always-present separator and label for JS to show/hide -->
                        <hr class="gg-sep" id="goals-sep" style="display: {% if goals %}''{% else %}none{% endif %};">
                        <div class="sub-label" id="goals-saved-label" style="display: {% if goals %}''{% else %}none{% endif %};"><i class="fas fa-save"></i> Your Saved Goals</div>
                        <div class="goal-grid" id="goals-container">
                            {% for g in goals %}
                            <div class="goal-card compact {% if g.is_primary %}is-primary{% endif %}" id="goal-card-{{ g.id }}">
                                <div class="goal-card-header">
                                    <h4>{{ g.career_title }}</h4>
                                    <span class="goal-card-type">{{ g.goal_type }}</span>
                                </div>
                                <div class="goal-card-body">
                                    <div class="match-stat">
                                        <span class="match-score">{{ g.match_count }} of {{ g.total_req }} skills</span>
                                        {% set pct = (g.match_count / g.total_req * 100) | round | int if g.total_req > 0 else 0 %}
                                        <span class="match-score">{{ pct }}%</span>
                                    </div>
                                    <div class="match-bar-bg">
                                        <div class="match-bar-fill" style="width: {{ pct }}%"></div>
                                    </div>

                                    <div class="sk-list">
                                        {% for s in g.skills %}
                                        <span class="sk-pill {% if s.matched %}matched{% endif %}">
                                            {% if s.matched %}<i class="fas fa-check"></i> {% endif %}{{ s.name }}
                                        </span>
                                        {% endfor %}
                                    </div>

                                    <p style="opacity: 0.7; font-size: 11px; margin-top: 10px; margin-bottom: 5px;">Field: {{ g.field_category or 'General' }}</p>
                                </div>
                                <div class="goal-card-footer">
                                    {% if not g.is_primary %}
                                    <button class="btn-card-action btn-set-primary" onclick="setPrimary({{ g.id }})">
                                        <i class="fas fa-star"></i> Set Primary
                                    </button>
                                    {% else %}
                                    <span class="type-badge type-core" style="background: var(--navy); color: #fff;">
                                        <i class="fas fa-check-circle"></i> Main Focus
                                    </span>
                                    {% endif %}
                                    <button class="btn-delete-goal" onclick="deleteGoal({{ g.id }})" title="Remove Goal">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>

                <!-- ══ STEP 3 · Add Grade ══ -->
                <div class="gg-card gg-collapsible" id="card-grade">
                    <div class="gg-card-header">
                        <h2><span class="step-number">4</span><i class="fas fa-plus-circle"></i> Add a Grade</h2>
                        <p>Each grade instantly recalculates your CGPA — no page refresh needed</p>
                    </div>
                    <div class="gg-card-body">
                        <div class="grade-grid">
                            <div class="fg">
                                <label>Course Name</label>
                                <input type="text" id="g-course" class="form-input" list="course-list"
                                    placeholder="e.g. Data Structures" autocomplete="off">
                                <datalist id="course-list">
                                    {% for c in all_courses %}
                                    <option value="{{ c.course_name | e }}" data-type="{{ c.course_type }}" data-credits="{{ c.credit_value }}">
                                    {% endfor %}
                                </datalist>
                            </div>
                            <div class="fg">
                                <label>Type</label>
                                <select id="g-type" class="form-input">
                                    <option value="Core">Core (Major)</option>
                                    <option value="GED">GED (Gen Ed)</option>
                                    <option value="Elective">Elective</option>
                                </select>
                            </div>
                            <div class="fg">
                                <label>Credits</label>
                                <input type="number" id="g-credits" class="form-input" value="3" min="1" max="6">
                            </div>
                            <div class="fg">
                                <label>Semester</label>
                                <select id="g-sem" class="form-input">
                                    {% for i in range(1, 13) %}
                                    <option value="{{ i }}">Sem {{ i }}{% if i <= 3 %} (Y1){% elif i <=6 %} (Y2){% elif
                                            i <=9 %} (Y3){% else %} (Y4){% endif %}</option>
                                            {% endfor %}
                                </select>
                            </div>
                            <div class="fg">
                                <label>Grade</label>
                                <select id="g-grade" class="form-input">
                                    <option value="">Grade…</option>
                                    <option value="A+">A+ (4.0)</option>
                                    <option value="A">A (4.0)</option>
                                    <option value="A-">A- (3.7)</option>
                                    <option value="B+">B+ (3.3)</option>
                                    <option value="B">B (3.0)</option>
                                    <option value="B-">B- (2.7)</option>
                                    <option value="C+">C+ (2.3)</option>
                                    <option value="C">C (2.0)</option>
                                    <option value="D">D (1.0)</option>
                                    <option value="F">F (0.0)</option>
                                </select>
                            </div>
                            <div class="fg">
                                <label>&nbsp;</label>
                                <button id="add-grade-btn" class="btn btn-primary" onclick="addGrade()"
                                    style="width:100%;padding:10px 14px;">
                                    <i class="fas fa-plus"></i> Add
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ══ STEP 4 · Academic Record ══ -->
                <div class="gg-card gg-collapsible" id="card-records">
                    <div class="gg-card-header">
                        <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
                            <div>
                                <h2><span class="step-number">5</span><i class="fas fa-graduation-cap"></i> Academic Record</h2>
                                <p>All grades — CGPA updates automatically</p>
                            </div>
                            <div class="cgpa-chip" id="cgpa-chip-header">
                                <i class="fas fa-chart-line" style="font-size:12px;"></i>
                                CGPA <span id="cgpa-chip-val">{{ student.current_cgpa or 'N/A' }}</span>
                            </div>
                        </div>
                    </div>
                    <div class="gg-card-body" style="padding-bottom:20px;">
                        <div class="records-scroll-wrap" id="records-wrap">
                            {% if records %}
                            <table class="mini-table" id="records-table">
                                <thead>
                                    <tr>
                                        <th>Course</th>
                                        <th>Type</th>
                                        <th>Semester</th>
                                        <th>Grade</th>
                                        <th>GPA pts</th>
                                        <th>Credits</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody id="records-tbody">
                                    {% for r in records %}
                                    <tr id="rec-{{ r.id }}">
                                        <td>{{ r.course_name | e }}</td>
                                        <td><span class="type-badge type-{{ r.course_type | lower }}">{{ r.course_type }}</span></td>
                                        <td>Sem {{ r.semester_taken }}</td>
                                        <td><strong>{{ r.grade }}</strong></td>
                                        <td>{{ r.grade_point }}</td>
                                        <td>{{ r.credit_value }}cr</td>
                                        <td>
                                            <button class="btn-del" onclick="deleteGrade({{ r.id }})" title="Delete"><i class="fas fa-trash"></i></button>
                                        </td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                            {% else %}
                            <div class="gg-empty" id="records-empty">
                                <i class="fas fa-book-open"></i>
                                <p>No grades yet. Add your first course grade above.</p>
                            </div>
                            {% endif %}
                        </div>
                    </div>
                </div>

            </div><!-- gg-layout -->
        </div><!-- dashboard-container -->

    <div id="gg-toast"><i class="fas fa-check-circle" id="gg-toast-icon"></i><span id="gg-toast-msg"></span></div>

    <script>
        // ═══════════════════════════════════════════════════════════
        //  Utilities
        // ═══════════════════════════════════════════════════════════
        function esc(s) {
            return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
        }

        function toast(msg, err = false) {
            const el = document.getElementById('gg-toast');
            const icon = document.getElementById('gg-toast-icon');
            el.className = 'show' + (err ? ' err' : '');
            icon.className = err ? 'fas fa-exclamation-circle' : 'fas fa-check-circle';
            document.getElementById('gg-toast-msg').textContent = msg;
            clearTimeout(el._t);
            el._t = setTimeout(() => el.classList.remove('show', 'err'), 3200);
        }

        async function api(url, body = null) {
            try {
                const opts = body !== null
                    ? { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) }
                    : { method: 'GET' };
                const r = await fetch(url, opts);
                if (!r.ok) {
                    let msg = `Server error (${r.status})`;
                    try { const e = await r.json(); msg = e.msg || e.error || msg; } catch (_) {}
                    toast(msg, true);
                    return { ok: false, msg };
                }
                return r.json();
            } catch (err) {
                toast('Network error — please check your connection', true);
                console.error('api() error:', err);
                return { ok: false, msg: 'Network error' };
            }
        }

        function setLoading(btn, on) {
            if (!btn) return;
            btn.disabled = on;
            if (on) { btn.dataset.orig = btn.innerHTML; btn.innerHTML = '<i class="fas fa-circle-notch spin"></i>'; }
            else btn.innerHTML = btn.dataset.orig;
        }

        // careerId → goalId map and lowercase title → goalId map, built from goals
        var careerGoalMap = new Map();
        var careerTitleMap = new Map();
        {% for g in goals %}
        careerGoalMap.set({{ g.career_id | tojson }}, {{ g.id | tojson }});
        careerTitleMap.set({{ (g.career_title or "") | lower | tojson }}, {{ g.id | tojson }});
        {% endfor %}


        // Snapshot career data as plain objects at init — DOM refs become stale when innerHTML is cleared
        var _careerSelectEl = document.getElementById('manual-career-select');
        var allCareerOptionsData = Array.from(_careerSelectEl.options).map(o => ({ value: o.value, text: o.text }));
        var defaultCareerOptionData = allCareerOptionsData[0];
        var careerOptionsData = allCareerOptionsData.slice(1); // [{value, text}, ...]

        // ═══════════════════════════════════════════════════════════
        //  Wizard: card reveal sequence
        // ═══════════════════════════════════════════════════════════
        var CARDS = ['card-skills', 'card-goals', 'card-grade', 'card-records'];
        var revealedUpTo = -1;

        function revealCardsUpTo(index) {
            CARDS.forEach((id, i) => {
                const el = document.getElementById(id);
                if (!el) return;
                if (i <= index && !el.classList.contains('card-visible')) {
                    setTimeout(() => {
                        el.classList.add('card-visible');
                        setTimeout(() => el.classList.add('card-flash'), 50);
                    }, (i - revealedUpTo - 1) * 160);
                }
            });
            revealedUpTo = Math.max(revealedUpTo, index);
        }


        // ═══════════════════════════════════════════════════════════
        //  Department selector
        // ═══════════════════════════════════════════════════════════
        var deptCache = new Map();
        // Department is now auto-loaded from the student's profile — no manual change listener needed.

        async function loadDeptData(dept, silent) {
            if (deptCache.has(dept)) {
                applyDeptData(deptCache.get(dept));
                return;
            }

            // Show loading state
            const pillsEl = document.getElementById('career-pills');
            const skillsEl = document.getElementById('skill-pills');
            const careersWrap = document.getElementById('dept-careers-wrap');
            const skillsWrap = document.getElementById('dept-skills-wrap');
            careersWrap.style.display = '';
            skillsWrap.style.display = '';
            pillsEl.innerHTML = '<span style="color:var(--muted);font-size:13px;"><i class="fas fa-circle-notch spin"></i> Loading career paths…</span>';
            skillsEl.innerHTML = '<span style="color:var(--muted);font-size:13px;"><i class="fas fa-circle-notch spin"></i> Loading skills…</span>';

            try {
                const r = await fetch(`/api/department-data?dept=${encodeURIComponent(dept)}`);
                if (!r.ok) throw new Error(`HTTP ${r.status}`);
                const d = await r.json();
                deptCache.set(dept, d);
                applyDeptData(d);
            } catch (err) {
                pillsEl.innerHTML = '<span style="color:var(--red);font-size:13px;"><i class="fas fa-exclamation-circle"></i> Failed to load career data. Please try again.</span>';
                skillsEl.innerHTML = '';
                console.error('loadDeptData error:', err);
            }
        }

        function applyDeptData(d) {
            buildCareerPills(d.careers || []);
            buildSkillChips(d.skills || []);

            // Rebuild select from static data snapshot (NOT from DOM — those refs go stale after innerHTML clear)
            const sel = document.getElementById('manual-career-select');
            sel.innerHTML = '';

            const defOpt = document.createElement('option');
            defOpt.value = defaultCareerOptionData.value;
            defOpt.textContent = defaultCareerOptionData.text;
            sel.appendChild(defOpt);

            const relevantNames = (d.careers || []).map(n => n.toLowerCase().trim());
            const relatedGrp = document.createElement('optgroup');
            relatedGrp.label = 'Suggested Paths';
            const otherGrp = document.createElement('optgroup');
            otherGrp.label = 'Other Paths';

            careerOptionsData.forEach(data => {
                const opt = document.createElement('option');
                opt.value = data.value;
                opt.textContent = data.text;
                if (relevantNames.includes(data.text.toLowerCase().trim())) {
                    relatedGrp.appendChild(opt);
                } else {
                    otherGrp.appendChild(opt);
                }
            });

            if (relatedGrp.children.length > 0) sel.appendChild(relatedGrp);
            if (otherGrp.children.length > 0) sel.appendChild(otherGrp);
        }

        function buildCareerPills(careers) {
            const grid = document.getElementById('career-pills');
            const wrap = document.getElementById('dept-careers-wrap');
            grid.innerHTML = '';

            careers.forEach(c => {
                let careerId = null;
                const cLower = c.toLowerCase().trim();
                // Look up from data snapshot (not stale DOM refs)
                for (let i = 0; i < careerOptionsData.length; i++) {
                    if (careerOptionsData[i].text.toLowerCase().trim() === cLower) {
                        careerId = parseInt(careerOptionsData[i].value);
                        break;
                    }
                }

                const btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'c-pill';
                btn.innerHTML = `<i class="fas fa-briefcase"></i> ${esc(c)}`;

                if ((careerId && careerGoalMap.has(careerId)) || careerTitleMap.has(cLower)) {
                    btn.classList.add('s-added');
                    btn.style.borderColor = '#d1d5db';
                    btn.style.background = '#f3f4f6';
                    btn.style.color = '#9ca3af';
                    btn.style.cursor = 'default';
                } else {
                    btn.onclick = async () => {
                        setLoading(btn, true);
                        const apiRes = await api('/api/gg/goal/add', { career_id: careerId, career_title: c, goal_type: 'Long Term' });
                        setLoading(btn, false);
                        if (!apiRes.ok) { toast(apiRes.msg || 'Error', true); return; }
                        toast('Goal added!');

                        if (apiRes.new_career_id) careerId = apiRes.new_career_id;

                        btn.classList.add('s-added');
                        btn.style.borderColor = '#d1d5db';
                        btn.style.background = '#f3f4f6';
                        btn.style.color = '#9ca3af';
                        btn.style.cursor = 'default';
                        btn.onclick = null;

                        await refreshGoalsTable();
                        if (careerId) swapCareerRowToRemove(careerId, apiRes.goal_id);
                    };
                }
                grid.appendChild(btn);
            });
            wrap.style.display = careers.length ? '' : 'none';
        }

        function buildSkillChips(skills) {
            const grid = document.getElementById('skill-pills');
            const wrap = document.getElementById('dept-skills-wrap');
            grid.innerHTML = '';
            skills.forEach(s => {
                const added = existingSkillNames.has(s.toLowerCase());
                const ch = document.createElement('button');
                ch.type = 'button';
                ch.className = 's-chip' + (added ? ' s-added' : '');
                ch.innerHTML = added ? `<i class="fas fa-check"></i> ${esc(s)}` : `<i class="fas fa-plus"></i> ${esc(s)}`;
                ch.title = added ? 'Already in your skills' : `Add "${s}"`;
                if (!added) ch.onclick = () => quickAddSkill(s, ch);
                grid.appendChild(ch);
            });
            wrap.style.display = skills.length ? '' : 'none';
        }

        // ═══════════════════════════════════════════════════════════
        //  Skills
        // ═══════════════════════════════════════════════════════════
        var existingSkillNames = new Set([{{ student_skills | map(attribute = 'skill_name') | map('tojson') | join(', ') }}].map(s => s.toLowerCase()));

        document.getElementById('skill-input').addEventListener('keydown', e => {
            if (e.key === 'Enter') { e.preventDefault(); addSkill(); }
        });

        async function addSkill() {
            const inp = document.getElementById('skill-input');
            const btn = document.getElementById('add-skill-btn');
            const name = inp.value.trim();
            if (!name) { inp.focus(); return; }
            setLoading(btn, true);
            const d = await api('/api/gg/skill/add', { skill_name: name });
            setLoading(btn, false);
            if (!d.ok) { toast(d.msg || 'Error adding skill', true); return; }
            inp.value = '';
            refreshSkillTags(d.skills);
            markChipAdded(name);
            await refreshGoalsTable(); // Re-fetch matches
            toast(`✓ "${name}" added`);
        }

        async function quickAddSkill(name, chipEl) {
            chipEl.className = 's-chip s-added';
            chipEl.innerHTML = `<i class="fas fa-check"></i> ${esc(name)}`;
            chipEl.onclick = null;
            const d = await api('/api/gg/skill/add', { skill_name: name });
            if (!d.ok) { toast(d.msg || 'Error', true); return; }
            refreshSkillTags(d.skills);
            await refreshGoalsTable(); // Re-fetch matches
            toast(`✓ "${name}" added`);
        }

        async function deleteSkill(skillId, btn) {
            setLoading(btn, true);
            const d = await api(`/api/gg/skill/${skillId}/delete`, {});
            if (!d.ok) { toast('Error removing skill', true); setLoading(btn, false); return; }
            refreshSkillTags(d.skills);
            await refreshGoalsTable(); // Re-fetch matches
            toast('Skill removed');
        }

        function markChipAdded(name) {
            document.querySelectorAll('#skill-pills .s-chip').forEach(ch => {
                const label = ch.textContent.trim().replace(/^[✓+]\s*/, '');
                if (label === name) {
                    ch.className = 's-chip s-added';
                    ch.innerHTML = `<i class="fas fa-check"></i> ${esc(name)}`;
                    ch.onclick = null;
                }
            });
        }

        function refreshSkillTags(skills) {
            existingSkillNames = new Set(skills.map(s => s.name.toLowerCase()));
            const area = document.getElementById('skill-tags-area');
            if (!skills.length) {
                area.innerHTML = '<div class="gg-empty" style="padding:10px 0;"><p>No skills yet.</p></div>';
                return;
            }
            area.innerHTML = skills.map(s =>
                `<div class="sk-tag" data-skill-id="${s.id}">
            <i class="fas fa-check" style="font-size:9px;"></i>
            ${esc(s.name)}
            <button onclick="deleteSkill(${s.id}, this)" title="Remove"><i class="fas fa-times"></i></button>
        </div>`
            ).join('');
            // Sync chip states
            document.querySelectorAll('#skill-pills .s-chip').forEach(ch => {
                const label = ch.textContent.trim().replace(/^[\u2713+]\s*/, '');
                const added = existingSkillNames.has(label.toLowerCase());
                ch.className = 's-chip' + (added ? ' s-added' : '');
                ch.innerHTML = added ? `<i class="fas fa-check"></i> ${esc(label)}` : `<i class="fas fa-plus"></i> ${esc(label)}`;
                ch.onclick = added ? null : () => quickAddSkill(label, ch);
            });
        }

        // ═══════════════════════════════════════════════════════════
        //  Target CGPA
        // ═══════════════════════════════════════════════════════════
        async function saveTargetCgpa() {
            const val = parseFloat(document.getElementById('target-cgpa-input').value);
            const btn = document.getElementById('cgpa-save-btn');
            if (isNaN(val) || val < 0 || val > 4.0) { toast('Enter a valid CGPA (0–4.0)', true); return; }
            setLoading(btn, true);
            const d = await api('/api/gg/target-cgpa', { target_cgpa: val });
            setLoading(btn, false);
            if (!d.ok) { toast('Error saving', true); return; }
            const st = document.getElementById('cgpa-save-status');
            st.style.opacity = 1;
            setTimeout(() => st.style.opacity = 0, 2000);
            toast('Target CGPA saved!');
        }

        // ═══════════════════════════════════════════════════════════
        //  Career Goals
        // ═══════════════════════════════════════════════════════════
        async function addManualGoal() {
            const careerId = parseInt(document.getElementById('manual-career-select').value);
            const goalType = document.getElementById('manual-goal-type').value;
            const btn = document.getElementById('add-manual-goal-btn');
            if (!careerId) { toast('Please select a career', true); return; }
            setLoading(btn, true);
            const d = await api('/api/gg/goal/add', { career_id: careerId, goal_type: goalType });
            setLoading(btn, false);
            if (!d.ok) { toast(d.msg || 'Error', true); return; }
            document.getElementById('manual-career-select').value = '';
            toast('Goal added!');
            await refreshGoalsTable();
            // Swap career row if visible
            swapCareerRowToRemove(careerId, d.goal_id);
        }

        function toggleMatches() {
            const dropdown = document.getElementById('matches-dropdown');
            if (dropdown) {
                dropdown.classList.toggle('is-active');
            }
        }

        async function addGoal(careerId) {
            const typeEl = document.getElementById(`gt-${careerId}`);
            const goalType = typeEl ? typeEl.value : 'Long Term';
            const btn = typeEl ? typeEl.nextElementSibling : null;
            if (btn) setLoading(btn, true);
            const d = await api('/api/gg/goal/add', { career_id: careerId, goal_type: goalType });
            if (btn) setLoading(btn, false);
            if (!d.ok) { toast(d.msg || 'Error', true); return; }
            toast('Goal added!');
            await refreshGoalsTable();
            return d; // Return result for chaining
        }

        async function addAndSetPrimary(careerId) {
            const d = await addGoal(careerId);
            if (d && d.ok && d.goal_id) {
                await setPrimary(d.goal_id);
            }
        }

        async function deleteGoal(goalId) {
            const d = await api(`/api/gg/goal/${goalId}/delete`, {});
            if (!d.ok) { toast('Error', true); return; }
            document.getElementById(`goal-card-${goalId}`)?.remove();
            // Find careerId from map and restore Add button
            for (const [cid, gid] of careerGoalMap) {
                if (gid === goalId) {
                    careerGoalMap.delete(cid);
                    restoreCareerRowAdd(cid);
                    break;
                }
            }
            toast('Goal removed');
        }

        async function deleteGoalByCareer(careerId) {
            const goalId = careerGoalMap.get(careerId);
            if (!goalId) { await refreshGoalsTable(); return; }
            const d = await api(`/api/gg/goal/${goalId}/delete`, {});
            if (!d.ok) { toast('Error', true); return; }
            careerGoalMap.delete(careerId);
            document.getElementById(`goal-card-${goalId}`)?.remove();
            restoreCareerRowAdd(careerId);
            toast('Goal removed');
        }

        function swapCareerRowToRemove(careerId, goalId) {
            const card = document.getElementById(`cr-${careerId}`);
            if (!card) return;
            
            const body = card.querySelector('.goal-card-body');
            const footer = card.querySelector('.goal-card-footer');
            
            // Add 'Added' indicator if not there
            if (body && !body.querySelector('.badge-added')) {
                // The badge was already in match-stat in the template, but let's ensure it's synced
            }
            
            footer.innerHTML = `
                <span class="type-badge type-core"><i class="fas fa-check"></i> Added</span>
                <button class="btn-delete-goal" onclick="deleteGoalByCareer(${careerId})">
                    <i class="fas fa-trash"></i>
                </button>
            `;
            if (goalId) careerGoalMap.set(careerId, goalId);
        }

        function restoreCareerRowAdd(careerId) {
            const card = document.getElementById(`cr-${careerId}`);
            if (!card) return;
            
            const footer = card.querySelector('.goal-card-footer');
            const header = card.querySelector('.career-actions');
            
            // Restore the select dropdown in header if it was removed (it might still be there)
            if (header && !header.innerHTML.trim()) {
                header.innerHTML = `
                    <select class="goal-type-sel" id="gt-${careerId}" style="padding: 2px 5px; height: 24px; font-size: 10px;">
                        <option value="Long Term">Long Term</option>
                        <option value="Short Term">Short Term</option>
                    </select>
                `;
            }

            footer.innerHTML = `
                <button class="btn-card-action btn-set-primary" onclick="addGoal(${careerId})" style="border-style: solid; background: var(--navy); color: #fff;">
                    <i class="fas fa-plus"></i> Add Goal
                </button>
            `;
        }

        async function setPrimary(goalId) {
            const d = await api(`/api/gg/goal/${goalId}/primary`, {});
            if (!d.ok) { toast('Error', true); return; }
            
            // Refresh the whole table to update all cards correctly
            await refreshGoalsTable();
            toast('Primary goal updated!');
        }

        async function refreshGoalsTable() {
            const d = await api('/api/gg/state');
            if (!d.ok) return;
            const goals = d.goals || [];

            // Update careerGoalMap and careerTitleMap
            careerGoalMap.clear();
            careerTitleMap.clear();
            goals.forEach(g => {
                careerGoalMap.set(g.career_id, g.id);
                careerTitleMap.set(g.career_title.toLowerCase(), g.id);
            });

            // Handle Saved Goals Container
            const goalsContainer = document.getElementById('goals-container');
            const sep = document.getElementById('goals-sep');
            const lbl = document.getElementById('goals-saved-label');

            if (!goals.length) {
                if (goalsContainer) goalsContainer.innerHTML = '';
                if (sep) sep.style.display = 'none';
                if (lbl) lbl.style.display = 'none';
            } else {
                if (sep) sep.style.display = '';
                if (lbl) lbl.style.display = '';
                if (goalsContainer) {
                    goalsContainer.innerHTML = goals.map(g => {
                        const pct = g.total_req > 0 ? Math.round(g.match_count / g.total_req * 100) : 0;
                        const skillPills = (g.skills || []).map(s => `
                            <span class="sk-pill ${s.matched ? 'matched' : ''}">
                                ${s.matched ? '<i class="fas fa-check"></i> ' : ''}${esc(s.name)}
                            </span>
                        `).join('');

                        return `
                        <div class="goal-card compact ${g.is_primary ? 'is-primary' : ''}" id="goal-card-${g.id}">
                            <div class="goal-card-header">
                                <h4>${esc(g.career_title)}</h4>
                                <span class="goal-card-type">${esc(g.goal_type)}</span>
                            </div>
                            <div class="goal-card-body">
                                <div class="match-stat">
                                    <span class="match-score">${g.match_count} of ${g.total_req} skills</span>
                                    <span class="match-score">${pct}%</span>
                                </div>
                                <div class="match-bar-bg">
                                    <div class="match-bar-fill" style="width: ${pct}%"></div>
                                </div>
                                <div class="sk-list">${skillPills}</div>
                                <p style="opacity: 0.7; font-size: 11px; margin-top: 10px; margin-bottom: 5px;">Field: ${esc(g.field_category || 'General')}</p>
                            </div>
                            <div class="goal-card-footer">
                                ${!g.is_primary 
                                    ? `<button class="btn-card-action btn-set-primary" onclick="setPrimary(${g.id})"><i class="fas fa-star"></i> Set Primary</button>`
                                    : `<span class="type-badge type-core" style="background: var(--navy); color: #fff;"><i class="fas fa-check-circle"></i> Main Focus</span>`
                                }
                                <button class="btn-delete-goal" onclick="deleteGoal(${g.id})" title="Remove Goal">
                                    <i class="fas fa-trash-alt"></i>
                                </button>
                            </div>
                        </div>`;
                    }).join('');
                }
            }

            // Handle Matching Careers Area
            const matchingArea = document.getElementById('matching-careers-area');
            if (matchingArea) {
                if (d.matching_careers && d.matching_careers.length > 0) {
                    matchingArea.innerHTML = '<div class="goal-grid">' + d.matching_careers.map(c => {
                        const isAdded = careerGoalMap.has(c.id);
                        const pct = c.total_req > 0 ? Math.round(c.match_count / c.total_req * 100) : 0;
                        const skillPills = (c.skills || []).map(s => `
                            <span class="sk-pill ${s.matched ? 'matched' : ''}">
                                ${s.matched ? '<i class="fas fa-check"></i> ' : ''}${esc(s.name)}
                            </span>
                        `).join('');

                        const actionsHeader = !isAdded 
                            ? `<select class="goal-type-sel" id="gt-${c.id}" style="padding: 2px 5px; height: 24px; font-size: 10px;">
                                <option value="Long Term">Long Term</option>
                                <option value="Short Term">Short Term</option>
                               </select>`
                            : '';

                        const actionsFooter = !isAdded
                            ? `<button class="btn-card-action btn-set-primary" onclick="addAndSetPrimary(${c.id})" style="border-style: solid; background: var(--gold); color: #fff; border-color: var(--gold); flex: 1;">
                                <i class="fas fa-star"></i> Set as Primary Goal
                               </button>
                               <button class="btn-card-action btn-set-primary" onclick="addGoal(${c.id})" style="border-style: solid; flex: 1;">
                                <i class="fas fa-plus"></i> Add to Goals
                               </button>`
                            : `<span class="type-badge type-core"><i class="fas fa-check"></i> Already Saved</span>
                               <button class="btn-delete-goal" onclick="deleteGoalByCareer(${c.id})">
                                <i class="fas fa-trash"></i>
                               </button>`;

                        return `
                        <div class="goal-card" id="cr-${c.id}">
                            <div class="goal-card-header">
                                <h4>${esc(c.title)}</h4>
                                <div class="career-actions">${actionsHeader}</div>
                            </div>
                            <div class="goal-card-body">
                                <div class="match-stat">
                                    <span class="match-score">${c.match_count} of ${c.total_req} skills</span>
                                    <span class="badge-added">${pct}% MATCH</span>
                                </div>
                                <div class="match-bar-bg">
                                    <div class="match-bar-fill" style="width: ${pct}%"></div>
                                </div>
                                <div class="sk-list">${skillPills}</div>
                                <p style="margin-top:10px; margin-bottom:0; opacity:0.8; font-size:11px;">Field: ${esc(c.field_category || 'General')}</p>
                            </div>
                            <div class="goal-card-footer">${actionsFooter}</div>
                        </div>`;
                    }).join('') + '</div>';
                } else {
                    matchingArea.innerHTML = `<div class="gg-empty">
                        <i class="fas fa-search"></i>
                        <p>Add skills above to see matching career paths here.</p>
                    </div>`;
                }
            }

            // Sync career pills for department section
            const dept = (document.getElementById('dept-select') || {}).value;
            if (dept && deptCache.has(dept)) {
                buildCareerPills(deptCache.get(dept).careers || []);
            }
        }

        // ═══════════════════════════════════════════════════════════
        //  Grades
        // ═══════════════════════════════════════════════════════════
        document.getElementById('g-course').addEventListener('change', function(e) {
            const val = e.target.value.trim().toLowerCase();
            const options = document.getElementById('course-list').options;
            for (let i = 0; i < options.length; i++) {
                if (options[i].value.toLowerCase() === val) {
                    const type = options[i].getAttribute('data-type');
                    const credits = options[i].getAttribute('data-credits');
                    if (type) document.getElementById('g-type').value = type;
                    if (credits) document.getElementById('g-credits').value = credits;
                    break;
                }
            }
        });

        async function addGrade() {
            const course = document.getElementById('g-course').value.trim();
            const type = document.getElementById('g-type').value;
            const credits = parseInt(document.getElementById('g-credits').value);
            const sem = parseInt(document.getElementById('g-sem').value);
            const grade = document.getElementById('g-grade').value;
            const btn = document.getElementById('add-grade-btn');

            if (!course) { toast('Course name required', true); return; }
            if (!grade) { toast('Select a grade', true); return; }

            setLoading(btn, true);
            const d = await api('/api/gg/grade/add', {
                course_name: course, course_type: type,
                credit_value: credits, semester: sem, grade,
            });
            setLoading(btn, false);

            if (!d.ok) { toast(d.msg || 'Error adding grade', true); return; }

            document.getElementById('g-course').value = '';
            document.getElementById('g-grade').value = '';

            // The endpoint returns new_cgpa — no second fetch needed
            updateCgpaDisplay(d.new_cgpa);
            toast(`Grade added! CGPA → ${d.new_cgpa ?? '—'}`);

            // Fetch updated records from state
            const state = await api('/api/gg/state', {});
            if (state.ok) renderRecords(state.records);
        }

        async function deleteGrade(recordId) {
            const d = await api(`/api/gg/grade/${recordId}/delete`, {});
            if (d.ok) {
                document.getElementById(`rec-${recordId}`)?.remove();
                updateCgpaDisplay(d.new_cgpa);
                toast('Grade removed');
            }
        }

        function updateCgpaDisplay(cgpa) {
            const val = cgpa ?? 'N/A';
            document.getElementById('live-cgpa').textContent = val;
            document.getElementById('cgpa-chip-val').textContent = val;
        }

        var TYPE_STYLE = { Core: 'type-core', GED: 'type-ged', Elective: 'type-elective' };

        function renderRecords(recs) {
            const wrap = document.getElementById('records-wrap');
            if (!recs || !recs.length) {
                wrap.innerHTML = `<div class="gg-empty" id="records-empty">
                    <i class="fas fa-book-open"></i>
                    <p>No grades yet. Add your first course grade above.</p>
                </div>`;
                return;
            }

            // Restore table if it was hidden
            if (!document.getElementById('records-table')) {
                wrap.innerHTML = `<table class="mini-table" id="records-table">
                    <thead>
                        <tr>
                            <th>Course</th>
                            <th>Type</th>
                            <th>Semester</th>
                            <th>Grade</th>
                            <th>GPA pts</th>
                            <th>Credits</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody id="records-tbody"></tbody>
                </table>`;
            }

            const tbody = document.getElementById('records-tbody');
            tbody.innerHTML = recs.map(r => `
                <tr id="rec-${r.id}">
                    <td>${esc(r.course_name)}</td>
                    <td><span class="type-badge ${TYPE_STYLE[r.course_type] || ''}">${esc(r.course_type)}</span></td>
                    <td>Sem ${r.semester_taken}</td>
                    <td><strong>${esc(r.grade)}</strong></td>
                    <td>${r.grade_point}</td>
                    <td>${r.credit_value}cr</td>
                    <td>
                        <button class="btn-del" onclick="deleteGrade(${r.id})" title="Delete"><i class="fas fa-trash"></i></button>
                    </td>
                </tr>
            `).join('');

            // Update datalist deduped
            const dl = document.getElementById('course-list');
            if (dl) {
                const seen = new Set();
                dl.innerHTML = recs.filter(r => {
                    if (seen.has(r.course_name)) return false;
                    seen.add(r.course_name); return true;
                }).map(r => `<option value="${esc(r.course_name)}">`).join('');
            }
        }

        // ═══════════════════════════════════════════════════════════
        //  Final initialization — deferred one paint so DOM is settled
        //  after both hard-load and SPA navigation script injection.
        // ═══════════════════════════════════════════════════════════
        (function initReveal() {
            var _retries = 0;
            function run() {
                var deptEl = document.getElementById('dept-select');
                if (!deptEl && _retries < 10) {
                    _retries++;
                    setTimeout(run, 100);
                    return;
                }
                try {
                    var dept = deptEl ? deptEl.value : '';
                    if (dept) {
                        revealCardsUpTo(3);
                        loadDeptData(dept, true);
                    } else {
                        revealCardsUpTo(0);
                    }
                } catch (e) {
                    console.warn('initReveal error:', e);
                    // Fallback: reveal all cards and still try to load dept data
                    CARDS.forEach(function(id) {
                        var el = document.getElementById(id);
                        if (el) el.classList.add('card-visible');
                    });
                    // Try loading dept data even in fallback
                    try {
                        var fallbackDept = deptEl ? deptEl.value : '';
                        if (fallbackDept) loadDeptData(fallbackDept, true);
                    } catch (_) {}
                }
            }
            if (typeof requestAnimationFrame === 'function') {
                requestAnimationFrame(function() { requestAnimationFrame(run); });
            } else {
                run();
            }
        })();
    </script>
    </main> <!-- /main-content -->
</body>

</html>


