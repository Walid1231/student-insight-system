<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Get Started | Student Insight</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --navy: #002D62;
            --blue: #3b82f6;
            --green: #10b981;
            --amber: #f59e0b;
            --purple: #8b5cf6;
            --red: #ef4444;
            --bg: #f1f5f9;
            --surface: #ffffff;
            --border: #e2e8f0;
            --muted: #64748b;
            --dark: #1e293b;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', system-ui, sans-serif;
            background: var(--bg);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
        }

        .page-wrap {
            width: 100%;
            max-width: 680px;
        }

        /* ── Header ── */
        .ob-header {
            text-align: center;
            margin-bottom: 36px;
        }

        .ob-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(59, 130, 246, 0.1);
            color: var(--blue);
            font-size: 13px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            padding: 6px 16px;
            border-radius: 50px;
            margin-bottom: 20px;
        }

        .ob-title {
            font-size: 34px;
            font-weight: 800;
            color: var(--dark);
            line-height: 1.2;
            margin-bottom: 12px;
        }

        .ob-title span {
            color: var(--blue);
        }

        .ob-subtitle {
            font-size: 15px;
            color: var(--muted);
            max-width: 460px;
            margin: 0 auto;
            line-height: 1.6;
        }

        /* ── Progress Bar ── */
        .progress-wrap {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 20px 24px;
            margin-bottom: 24px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
        }

        .progress-meta {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }

        .progress-label {
            font-size: 14px;
            font-weight: 600;
            color: var(--dark);
        }

        .progress-count {
            font-size: 14px;
            font-weight: 700;
            color: var(--blue);
        }

        .progress-track {
            height: 8px;
            background: var(--border);
            border-radius: 50px;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            border-radius: 50px;
            background: linear-gradient(90deg, var(--blue), #60a5fa);
            transition: width 0.6s ease;
        }

        /* ── Step Cards ── */
        .steps-list {
            display: flex;
            flex-direction: column;
            gap: 14px;
            margin-bottom: 28px;
        }

        .step-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 18px 20px;
            display: flex;
            align-items: center;
            gap: 18px;
            box-shadow: 0 2px 6px rgba(0, 0, 0, 0.04);
            transition: transform 0.15s, box-shadow 0.15s;
            text-decoration: none;
            color: inherit;
        }

        .step-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
        }

        .step-card.done {
            border-color: #bbf7d0;
            background: #f0fdf4;
        }

        .step-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            flex-shrink: 0;
        }

        .step-icon.blue {
            background: rgba(59, 130, 246, 0.12);
            color: var(--blue);
        }

        .step-icon.green {
            background: rgba(16, 185, 129, 0.12);
            color: var(--green);
        }

        .step-icon.amber {
            background: rgba(245, 158, 11, 0.12);
            color: var(--amber);
        }

        .step-icon.purple {
            background: rgba(139, 92, 246, 0.12);
            color: var(--purple);
        }

        .step-icon.done-icon {
            background: rgba(16, 185, 129, 0.15);
            color: var(--green);
        }

        .step-body {
            flex: 1;
        }

        .step-title {
            font-size: 15px;
            font-weight: 700;
            color: var(--dark);
            margin-bottom: 3px;
        }

        .step-desc {
            font-size: 13px;
            color: var(--muted);
        }

        .step-status {
            flex-shrink: 0;
            width: 28px;
            height: 28px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
        }

        .step-status.done-badge {
            background: var(--green);
            color: #fff;
        }

        .step-status.pending-badge {
            background: var(--border);
            color: var(--muted);
        }

        /* ── CTA ── */
        .cta-row {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .btn-primary {
            flex: 1;
            min-width: 200px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 14px 24px;
            background: var(--navy);
            color: #fff;
            border-radius: 10px;
            font-size: 15px;
            font-weight: 700;
            text-decoration: none;
            transition: background 0.2s, transform 0.1s;
        }

        .btn-primary:hover {
            background: #004080;
            transform: translateY(-1px);
        }

        .btn-ghost {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 14px 24px;
            background: transparent;
            color: var(--muted);
            border: 1px solid var(--border);
            border-radius: 10px;
            font-size: 14px;
            font-weight: 600;
            text-decoration: none;
            transition: background 0.15s;
        }

        .btn-ghost:hover {
            background: var(--surface);
            color: var(--dark);
        }

        /* ── Tip Banner ── */
        .tip-banner {
            margin-top: 24px;
            background: rgba(59, 130, 246, 0.06);
            border: 1px solid rgba(59, 130, 246, 0.2);
            border-radius: 10px;
            padding: 14px 18px;
            display: flex;
            gap: 12px;
            align-items: flex-start;
            font-size: 13px;
            color: var(--muted);
            line-height: 1.5;
        }

        .tip-banner i {
            color: var(--blue);
            margin-top: 2px;
            flex-shrink: 0;
        }

        /* ── Done CTA ── */
        .all-done {
            text-align: center;
            padding: 20px;
            background: #f0fdf4;
            border: 1px solid #bbf7d0;
            border-radius: 14px;
            margin-bottom: 24px;
        }

        .all-done i {
            font-size: 36px;
            color: var(--green);
            margin-bottom: 10px;
            display: block;
        }

        .all-done h3 {
            font-size: 20px;
            font-weight: 800;
            color: var(--dark);
            margin-bottom: 6px;
        }

        .all-done p {
            font-size: 14px;
            color: var(--muted);
        }
    </style>
</head>

<body>

    <div class="page-wrap">

        <!-- Header -->
        <div class="ob-header">
            <div class="ob-badge"><i class="fas fa-rocket"></i> Getting Started</div>
            <h1 class="ob-title">Welcome, <span>{{ data.name }}</span>!</h1>
            <p class="ob-subtitle">Complete these 4 quick steps to unlock your personalised dashboard with live charts
                and AI insights.</p>
        </div>

        <!-- Progress -->
        <div class="progress-wrap">
            <div class="progress-meta">
                <span class="progress-label">Setup Progress</span>
                <span class="progress-count">{{ data.steps_done }} / 4 Complete</span>
            </div>
            <div class="progress-track">
                <div class="progress-fill" style="width: {{ (data.steps_done / 4 * 100) | int }}%;"></div>
            </div>
        </div>

        {% if data.steps_done == 3 %}
        <div class="all-done">
            <i class="fas fa-star"></i>
            <h3>Almost there — 1 step left!</h3>
            <p>Complete the last step to activate all charts on your dashboard.</p>
        </div>
        {% endif %}

        <!-- Steps -->
        <div class="steps-list">

            <!-- Step 1: Add Grades -->
            <a href="/student/goals-grades" class="step-card {% if data.has_grades %}done{% endif %}">
                <div class="step-icon {% if data.has_grades %}done-icon{% else %}blue{% endif %}">
                    <i class="fas {% if data.has_grades %}fa-check{% else %}fa-graduation-cap{% endif %}"></i>
                </div>
                <div class="step-body">
                    <div class="step-title">Add Your First Grade</div>
                    <div class="step-desc">
                        {% if data.has_grades %}
                        Grades added ✓ — CGPA Trend and Course Distribution charts are ready.
                        {% else %}
                        Go to Goals &amp; Grades → Add Grade. Enter at least 1 course with a grade to activate CGPA
                        charts.
                        {% endif %}
                    </div>
                </div>
                <div class="step-status {% if data.has_grades %}done-badge{% else %}pending-badge{% endif %}">
                    <i class="fas {% if data.has_grades %}fa-check{% else %}fa-chevron-right{% endif %}"></i>
                </div>
            </a>

            <!-- Step 2: Add Skills -->
            <a href="/student/goals-grades#skills" class="step-card {% if data.has_skills %}done{% endif %}">
                <div class="step-icon {% if data.has_skills %}done-icon{% else %}green{% endif %}">
                    <i class="fas {% if data.has_skills %}fa-check{% else %}fa-crosshairs{% endif %}"></i>
                </div>
                <div class="step-body">
                    <div class="step-title">Select At Least 3 Skills</div>
                    <div class="step-desc">
                        {% if data.has_skills %}
                        Skills saved ✓ — Skill Radar chart is active.
                        {% else %}
                        Go to Goals &amp; Grades → Skills section. Pick skills that reflect your strengths to activate
                        the radar chart.
                        {% endif %}
                    </div>
                </div>
                <div class="step-status {% if data.has_skills %}done-badge{% else %}pending-badge{% endif %}">
                    <i class="fas {% if data.has_skills %}fa-check{% else %}fa-chevron-right{% endif %}"></i>
                </div>
            </a>

            <!-- Step 3: Log Study Session -->
            <a href="/student/weekly-routine" class="step-card {% if data.has_sessions %}done{% endif %}">
                <div class="step-icon {% if data.has_sessions %}done-icon{% else %}amber{% endif %}">
                    <i class="fas {% if data.has_sessions %}fa-check{% else %}fa-calendar-alt{% endif %}"></i>
                </div>
                <div class="step-body">
                    <div class="step-title">Log 1 Study Session</div>
                    <div class="step-desc">
                        {% if data.has_sessions %}
                        Session logged ✓ — Weekly Hours and Skill Effort charts will reflect recent sessions.
                        {% else %}
                        Go to Weekly Routine and add a study session. Tag it with a skill to also power the Skill Effort
                        chart.
                        {% endif %}
                    </div>
                </div>
                <div class="step-status {% if data.has_sessions %}done-badge{% else %}pending-badge{% endif %}">
                    <i class="fas {% if data.has_sessions %}fa-check{% else %}fa-chevron-right{% endif %}"></i>
                </div>
            </a>

            <!-- Step 4: Set a Career Goal -->
            <a href="/student/goals-grades#goals" class="step-card {% if data.has_goals %}done{% endif %}">
                <div class="step-icon {% if data.has_goals %}done-icon{% else %}purple{% endif %}">
                    <i class="fas {% if data.has_goals %}fa-check{% else %}fa-bullseye{% endif %}"></i>
                </div>
                <div class="step-body">
                    <div class="step-title">Set 1 Career Goal</div>
                    <div class="step-desc">
                        {% if data.has_goals %}
                        Goal set ✓ — Career Compatibility and Goal Achievability charts are active.
                        {% else %}
                        Go to Goals &amp; Grades → Goals section and pick a career path to unlock career charts.
                        {% endif %}
                    </div>
                </div>
                <div class="step-status {% if data.has_goals %}done-badge{% else %}pending-badge{% endif %}">
                    <i class="fas {% if data.has_goals %}fa-check{% else %}fa-chevron-right{% endif %}"></i>
                </div>
            </a>

        </div>

        <!-- CTA Row -->
        <div class="cta-row">
            <a href="/student/dashboard" class="btn-primary">
                <i class="fas fa-chart-line"></i>
                Go to Dashboard
            </a>
            <a href="/student/goals-grades" class="btn-ghost">
                <i class="fas fa-arrow-right"></i>
                Start with Grades &amp; Goals
            </a>
        </div>

        <!-- Tip -->
        <div class="tip-banner">
            <i class="fas fa-lightbulb"></i>
            <span>You can access the dashboard at any time — charts will show an empty-state guide for any data you
                haven't added yet. Complete all 4 steps to see the full picture.</span>
        </div>

    </div>
</body>

</html>


================================================================================
FILE: templates\student_profile.html
================================================================================

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>My Profile | Student Insight</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- Unified Styles -->
    <link rel="stylesheet" href="{{ url_for('static', filename='css/unified_styles.css') }}?v=2">
    <link href="{{ url_for('static', filename='css/ui_alerts.css') }}" rel="stylesheet">
    <script src="{{ url_for('static', filename='js/ui_alerts.js') }}"></script>
</head>

<body class="preload">

    {% set active_page = 'profile' %}
    {% include 'components/sidebar.html' %}

    <div class="main-content">
        <!-- 1. HEADER (Always Visible) -->
        <div class="profile-header">
            <div class="profile-img-container">
                <img src="{{ url_for('static', filename='uploads/profile_pics/' + student.profile_picture) if student.profile_picture else 'https://ui-avatars.com/api/?name=' + student.full_name + '&background=0D8ABC&color=fff' }}"
                    alt="Profile" class="profile-img" id="profileDisplay">
                <label for="profile_upload" class="upload-btn">
                    <i class="fas fa-camera"></i>
                </label>
            </div>
            <div class="profile-info">
                <h1 id="header-name">{{ student.full_name }}</h1>
                <!-- Only show fields that exist in this quick header view -->
                {% if student.university %}
                <p><i class="fas fa-university" style="margin-right: 5px; color: var(--accent-gold);"></i>{{
                    student.university }}</p>
                {% else %}
                <p>{{ student.email }}</p>
                {% endif %}
            </div>
        </div>

        <!-- 2. READ-ONLY VIEW (Default) -->
        <div id="read-only-view" class="card">
            <div class="card-header">
                <div class="card-title"><i class="fas fa-id-card"></i> Profile Details</div>
                <!-- EDIT BUTTON -->
                <button class="btn-action btn-edit" onclick="toggleEditMode()">
                    <i class="fas fa-edit"></i> Edit Profile
                </button>
            </div>

            <div class="info-grid">
                <!-- Conditionally Render Fields -->
                {% if student.full_name %}
                <div class="info-group">
                    <div class="info-label">Full Name</div>
                    <div class="info-value" id="display-name">{{ student.full_name }}</div>
                </div>
                {% endif %}

                {% if student.email %}
                <div class="info-group">
                    <div class="info-label">Email</div>
                    <div class="info-value">{{ student.email }}</div>
                </div>
                {% endif %}

                {% if student.university %}
                <div class="info-group">
                    <div class="info-label">University</div>
                    <div class="info-value" id="display-university">{{ student.university }}</div>
                </div>
                {% endif %}

                {% if student.department %}
                <div class="info-group">
                    <div class="info-label">Department</div>
                    <div class="info-value" id="display-department">{{ student.department }}</div>
                </div>
                {% endif %}

                {% if student.current_year %}
                <div class="info-group">
                    <div class="info-label">Year</div>
                    <div class="info-value" id="display-year">{{ student.current_year }}</div>
                </div>
                {% endif %}

                {% if student.cgpa %}
                <div class="info-group">
                    <div class="info-label">Target CGPA</div>
                    <div class="info-value" id="display-cgpa">{{ student.cgpa }}</div>
                </div>
                {% endif %}

                {% if student.career_goal %}
                <div class="info-group full-width">
                    <div class="info-label">Career Goal</div>
                    <div class="info-value" id="display-career-goal">{{ student.career_goal }}</div>
                </div>
                {% endif %}

                {% if student.bio %}
                <div class="info-group full-width">
                    <div class="info-label">Bio</div>
                    <div class="info-value bio" id="display-bio">{{ student.bio }}</div>
                </div>
                {% endif %}

                {% if student.linkedin_profile %}
                <div class="info-group">
                    <div class="info-label">LinkedIn</div>
                    <div class="info-value"><a href="{{ student.linkedin_profile }}" id="display-linkedin" target="_blank">View Profile</a>
                    </div>
                </div>
                {% endif %}

                {% if student.github_profile %}
                <div class="info-group">
                    <div class="info-label">GitHub</div>
                    <div class="info-value"><a href="{{ student.github_profile }}" id="display-github" target="_blank">View Profile</a>
                    </div>
                </div>
                {% endif %}
            </div>

            <div class="action-bar">
                <button class="btn-action btn-cancel" style="border-color: #ef4444; color: #ef4444;"
                    onclick="confirmDeleteProfile(event)">
                    <i class="fas fa-trash-alt"></i> Delete Account
                </button>
            </div>
        </div>

        <!-- 3. EDIT VIEW (Hidden by default) -->
        <div id="edit-view" class="card hidden">
            <div class="card-header">
                <div class="card-title"><i class="fas fa-user-edit"></i> Edit Profile</div>
            </div>

            <form action="{{ url_for('dashboard.student_profile') }}" method="POST" enctype="multipart/form-data" id="profile-form" onsubmit="handleProfileSubmit(event)">
                <input type="file" id="profile_upload" name="profile_picture" accept="image/*" style="display: none;"
                    onchange="previewImage(this)">

                <div class="form-grid">
                    <!-- Basic Info -->
                    <div class="form-section-title">Basic Information</div>

                    <div class="form-group">
                        <label>Full Name</label>
                        <input type="text" class="form-control" name="full_name" value="{{ student.full_name }}">
                    </div>

                    <div class="form-group">
                        <label>University / College</label>
                        <input type="text" class="form-control" name="university" value="{{ student.university or '' }}"
                            placeholder="e.g. Daffodil International University">
                    </div>

                    <div class="form-group">
                        <label>Department</label>
                        <select spellcheck="false" class="form-control" name="department" id="department-select">
                            <option value="">— Choose your department —</option>
                            {% for group_name, depts in dept_groups %}
                            <optgroup label="{{ group_name }}">
                                {% for dept in depts %}
                                <option value="{{ dept }}" {% if student.department == dept %}selected{% endif %}>{{ dept }}</option>
                                {% endfor %}
                            </optgroup>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Current Year</label>
                        <select class="form-control" name="current_year">
                            <option value="1st Year" {% if student.current_year=='1st Year' %}selected{% endif %}>1st
                                Year</option>
                            <option value="2nd Year" {% if student.current_year=='2nd Year' %}selected{% endif %}>2nd
                                Year</option>
                            <option value="3rd Year" {% if student.current_year=='3rd Year' %}selected{% endif %}>3rd
                                Year</option>
                            <option value="4th Year" {% if student.current_year=='4th Year' %}selected{% endif %}>4th
                                Year</option>
                        </select>
                    </div>

                    <!-- Goals -->
                    <div class="form-section-title">Goals & Links</div>

                    <div class="form-group">
                        <label>Target CGPA</label>
                        <input type="number" step="0.01" class="form-control" name="cgpa"
                            value="{{ student.cgpa or '' }}" placeholder="4.00">
                    </div>

                    <div class="form-group">
                        <label>Career Goal</label>
                        <input type="text" class="form-control" name="career_goal"
                            value="{{ student.career_goal or '' }}" placeholder="e.g. Software Engineer">
                    </div>

                    <div class="form-group">
                        <label>LinkedIn Profile URL</label>
                        <input type="url" class="form-control" name="linkedin_profile"
                            value="{{ student.linkedin_profile or '' }}" placeholder="https://linkedin.com/in/...">
                    </div>

                    <div class="form-group">
                        <label>GitHub Profile URL</label>
                        <input type="url" class="form-control" name="github_profile"
                            value="{{ student.github_profile or '' }}" placeholder="https://github.com/...">
                    </div>

                    <div class="form-section-title">About Me</div>
                    <div class="form-group">
                        <label>Bio</label>
                        <textarea class="form-control" name="bio"
                            placeholder="Tell us about yourself...">{{ student.bio or '' }}</textarea>
                    </div>
                </div>

                <div class="action-bar">
                    <button type="button" class="btn-action btn-cancel" onclick="toggleEditMode()">Cancel</button>
                    <button type="submit" class="btn-action btn-save">Save Changes</button>
                </div>
            </form>
        </div>

    <!-- DELETE MODAL -->
    <div class="modal-overlay" id="deleteModal">
        <div class="modal-dialog">
            <div class="modal-header">
                <div class="modal-title">Delete Account</div>
            </div>
            <div class="modal-body">
                <p class="modal-warning-text">Are you sure you want to delete your account? This action cannot be
                    undone.</p>
            </div>
            <div class="modal-footer">
                <button class="modal-btn modal-btn-ok" onclick="executeDeleteProfile()">Yes, Delete</button>
                <button class="modal-btn modal-btn-cancel" onclick="closeDeleteModal()">Cancel</button>
            </div>
        </div>
    </div>

    <script>
        // ═══════════════════════════════════════════════════════
        //  PROFILE PAGE — SPA-safe, self-contained script
        //  Works on both full page load AND sidebar SPA navigation
        // ═══════════════════════════════════════════════════════
        (function profilePageInit() {
            // ── Polyfill showToast if ui_alerts.js wasn't loaded via SPA ──
            if (typeof showToast !== 'function') {
                window.showToast = function(msg, type) {
                    var t = document.createElement('div');
                    t.textContent = msg;
                    t.style.cssText = 'position:fixed;top:24px;right:24px;padding:14px 20px;border-radius:8px;color:#fff;font-size:14px;font-weight:500;z-index:10001;opacity:0;transform:translateY(-10px);transition:all .3s ease;';
                    t.style.background = (type === 'error') ? '#ef4444' : '#059669';
                    document.body.appendChild(t);
                    requestAnimationFrame(function() { t.style.opacity = '1'; t.style.transform = 'translateY(0)'; });
                    setTimeout(function() { t.style.opacity = '0'; setTimeout(function() { t.remove(); }, 300); }, 3000);
                };
            }

            var _originalImgSrc = '';

            function getEls() {
                return {
                    readOnly: document.getElementById('read-only-view'),
                    edit: document.getElementById('edit-view'),
                    form: document.getElementById('profile-form'),
                    img: document.getElementById('profileDisplay'),
                    headerName: document.getElementById('header-name'),
                    deleteModal: document.getElementById('deleteModal')
                };
            }

            window.toggleEditMode = function() {
                var els = getEls();
                if (!els.readOnly || !els.edit) return;

                if (els.readOnly.classList.contains('hidden')) {
                    if (els.form) els.form.reset();
                    if (_originalImgSrc && els.img) els.img.src = _originalImgSrc;
                    els.edit.classList.add('hidden');
                    els.readOnly.classList.remove('hidden');
                    els.readOnly.style.animation = 'none';
                    void els.readOnly.offsetHeight;
                    els.readOnly.style.animation = 'profileFadeIn 0.3s ease both';
                } else {
                    if (els.img) _originalImgSrc = els.img.src;
                    els.readOnly.classList.add('hidden');
                    els.edit.classList.remove('hidden');
                    els.edit.style.animation = 'none';
                    void els.edit.offsetHeight;
                    els.edit.style.animation = 'profileFadeIn 0.3s ease both';
                }
            };

            window.previewImage = function(input) {
                if (input.files && input.files[0]) {
                    var reader = new FileReader();
                    reader.onload = function(e) {
                        var img = document.getElementById('profileDisplay');
                        if (img) img.src = e.target.result;
                    };
                    reader.readAsDataURL(input.files[0]);
                }
            };

            function updateOrInject(id, labelText, valueHTML, isFullWidth, isLink) {
                var el = document.getElementById(id);
                if (!valueHTML) {
                    if (el) el.closest('.info-group').style.display = 'none';
                    return;
                }
                if (el) {
                    el.closest('.info-group').style.display = 'block';
                    if (isLink) { el.href = valueHTML; }
                    else { el.textContent = valueHTML; }
                } else {
                    var grid = document.querySelector('.info-grid');
                    if (!grid) return;
                    var group = document.createElement('div');
                    group.className = 'info-group' + (isFullWidth ? ' full-width' : '');
                    var label = document.createElement('div');
                    label.className = 'info-label';
                    label.textContent = labelText;
                    var val = document.createElement('div');
                    val.className = 'info-value' + (id === 'display-bio' ? ' bio' : '');
                    if (isLink) { val.innerHTML = '<a id="' + id + '" href="' + valueHTML + '" target="_blank">View Profile</a>'; }
                    else { val.id = id; val.textContent = valueHTML; }
                    group.appendChild(label);
                    group.appendChild(val);
                    grid.appendChild(group);
                }
            }

            window.handleProfileSubmit = function(event) {
                event.preventDefault();
                var form = event.target;
                var formData = new FormData(form);
                formData.append('_ajax', '1');

                var btn = form.querySelector('.btn-save');
                if (!btn) return;
                var oldText = btn.innerHTML;
                btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving...';
                btn.disabled = true;

                fetch(form.action || '/student/profile', {
                    method: 'POST',
                    body: formData,
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data.success) {
                        showToast('Profile updated successfully', 'success');
                        var els = getEls();
                        if (els.headerName) els.headerName.textContent = data.name;
                        updateOrInject('display-name', 'Full Name', data.name);
                        updateOrInject('display-university', 'University', data.university);
                        updateOrInject('display-department', 'Department', data.department);
                        updateOrInject('display-year', 'Year', data.current_year);
                        updateOrInject('display-cgpa', 'Target CGPA', data.cgpa);
                        updateOrInject('display-career-goal', 'Career Goal', data.career_goal, true);
                        updateOrInject('display-bio', 'Bio', data.bio, true);
                        updateOrInject('display-linkedin', 'LinkedIn', data.linkedin, false, true);
                        updateOrInject('display-github', 'GitHub', data.github, false, true);
                        if (data.profile_picture && els.img) {
                            els.img.src = '/static/uploads/profile_pics/' + data.profile_picture;
                        } else if (els.img && els.img.src.includes('ui-avatars.com') && data.name) {
                            var url = new URL(els.img.src);
                            url.searchParams.set('name', data.name);
                            els.img.src = url.toString();
                        }
                        Array.from(form.elements).forEach(function(el) {
                            if (el.name && el.name !== 'profile_picture') {
                                if (el.type === 'select-one') {
                                    Array.from(el.options).forEach(function(opt) { opt.defaultSelected = opt.selected; });
                                } else if (el.type !== 'file') {
                                    el.defaultValue = el.value;
                                }
                            }
                        });
                        if (els.img) _originalImgSrc = els.img.src;
                        setTimeout(function() { toggleEditMode(); }, 200);
                    } else {
                        showToast(data.error || 'Validation failed.', 'error');
                    }
                })
                .catch(function(err) {
                    console.error('Profile save error:', err);
                    showToast('Network error saving profile.', 'error');
                })
                .finally(function() {
                    btn.innerHTML = oldText;
                    btn.disabled = false;
                });
            };

            window.confirmDeleteProfile = function(event) {
                event.preventDefault();
                var m = document.getElementById('deleteModal');
                if (m) m.classList.add('active');
            };
            window.closeDeleteModal = function() {
                var m = document.getElementById('deleteModal');
                if (m) m.classList.remove('active');
            };
            window.executeDeleteProfile = function() {
                closeDeleteModal();
                fetch('/student/delete-profile', { method: 'DELETE', headers: { 'Content-Type': 'application/json' } })
                    .then(function(r) { return r.json(); })
                    .then(function(d) {
                        if (d.success) { showToast('Profile deleted.', 'success'); window.location.href = '/'; }
                        else showToast('Error: ' + d.error, 'error');
                    })
                    .catch(function() { showToast('Error deleting profile.', 'error'); });
            };

            var dm = document.getElementById('deleteModal');
            if (dm) dm.addEventListener('click', function(e) { if (e.target === this) closeDeleteModal(); });

            if (!document.getElementById('profile-anim-style')) {
                var s = document.createElement('style');
                s.id = 'profile-anim-style';
                s.textContent = '@keyframes profileFadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }';
                document.head.appendChild(s);
            }
        })();
    </script>
    </div> <!-- /main-content -->
</body>
</html>


