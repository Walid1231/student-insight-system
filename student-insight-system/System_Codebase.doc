<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Professional CV | Student Insight System</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <style>
        :root {
            --primary-navy: #002D62;
            --accent-gold: #D4AF37;
            --glass-bg: rgba(255, 255, 255, 0.85);
            --text-dark: #1a1a1a;
            --text-muted: #555;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            color: var(--text-dark);
            min-height: 100vh;
            padding: 40px 20px;
        }

        .container {
            max-width: 1000px;
            margin: 0 auto;
        }

        /* GLASS CARD */
        .glass-card {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.5);
            border-radius: 24px;
            box-shadow: 0 20px 60px rgba(0, 45, 98, 0.12);
            overflow: hidden;
            margin-bottom: 40px;
        }

        /* HEADER */
        .card-header {
            background: linear-gradient(135deg, var(--primary-navy) 0%, #003d7a 100%);
            color: white;
            padding: 40px;
            text-align: center;
        }

        .card-header h1 {
            margin: 0;
            font-weight: 800;
            font-size: 32px;
        }

        .card-header p {
            margin: 10px 0 0;
            opacity: 0.9;
            font-size: 16px;
        }

        /* CARD BODY */
        .card-body {
            padding: 40px;
        }

        /* SECTION */
        .form-section {
            margin-bottom: 40px;
        }

        .section-title {
            font-size: 18px;
            font-weight: 700;
            color: var(--primary-navy);
            margin-bottom: 20px;
            padding-bottom: 12px;
            border-bottom: 2px solid #e8ecef;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .section-title::before {
            content: '';
            width: 4px;
            height: 24px;
            background: var(--accent-gold);
            border-radius: 2px;
        }

        /* FORM GRID */
        .form-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
        }

        /* FORM GROUP */
        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            font-weight: 600;
            font-size: 13px;
            color: #333;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .form-group label .required {
            color: #dc3545;
            margin-left: 4px;
        }

        /* FORM CONTROLS */
        .form-control {
            width: 100%;
            padding: 14px 18px;
            border: 2px solid #e8ecef;
            border-radius: 12px;
            font-size: 15px;
            font-family: 'Inter', sans-serif;
            transition: all 0.3s ease;
            background: white;
        }

        .form-control:focus {
            outline: none;
            border-color: var(--primary-navy);
            box-shadow: 0 0 0 4px rgba(0, 45, 98, 0.08);
            transform: translateY(-1px);
        }

        .form-control::placeholder {
            color: #aaa;
            font-size: 14px;
        }

        textarea.form-control {
            resize: vertical;
            min-height: 100px;
        }

        /* DYNAMIC LISTS */
        .dynamic-list {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .list-item {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 12px;
            border: 2px solid #e8ecef;
            position: relative;
            animation: slideIn 0.3s ease;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .list-item-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }

        .list-item-title {
            font-weight: 700;
            font-size: 14px;
            color: var(--primary-navy);
        }

        .btn-remove {
            background: #dc3545;
            border: none;
            color: white;
            width: 32px;
            height: 32px;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.2s ease;
            font-size: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .btn-remove:hover {
            background: #c82333;
            transform: scale(1.05);
        }

        .btn-add {
            background: var(--primary-navy);
            border: none;
            color: white;
            padding: 12px 24px;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 14px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin-top: 10px;
        }

        .btn-add:hover {
            background: #003d7a;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(0, 45, 98, 0.2);
        }

        /* SUBMIT BUTTON */
        .btn-submit {
            width: 100%;
            background: linear-gradient(135deg, var(--accent-gold) 0%, #c49b30 100%);
            border: none;
            color: white;
            font-weight: 700;
            padding: 18px 40px;
            border-radius: 14px;
            font-size: 16px;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            transition: all 0.3s ease;
            cursor: pointer;
            margin-top: 30px;
            box-shadow: 0 8px 20px rgba(212, 175, 55, 0.25);
        }

        .btn-submit:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 30px rgba(212, 175, 55, 0.35);
        }

        /* BACK LINK */
        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: var(--primary-navy);
            text-decoration: none;
            font-weight: 600;
            margin-bottom: 20px;
            transition: 0.3s;
        }

        .back-link:hover {
            gap: 12px;
        }

        /* RESPONSIVE */
        @media (max-width: 768px) {
            .card-header {
                padding: 30px 25px;
            }

            .card-header h1 {
                font-size: 26px;
            }

            .card-body {
                padding: 25px;
            }

            .form-grid {
                grid-template-columns: 1fr;
            }
        }

        /* HELPER TEXT */
        .helper-text {
            font-size: 12px;
            color: #888;
            margin-top: 6px;
            display: block;
        }
    </style>
</head>

<body>
    <div class="container">
        <a href="/student/dashboard" class="back-link">
            <span>←</span>
            <span>Back to Dashboard</span>
        </a>

        <div class="glass-card">
            <div class="card-header">
                <h1>Create Professional CV</h1>
                <p>Build your resume following international professional standards</p>
            </div>
            <div class="card-body">
                <form method="POST" action="/create-profile" enctype="multipart/form-data" id="cvForm">

                    <!-- CONTACT INFORMATION -->
                    <div class="form-section">
                        <div class="section-title">Contact Information</div>
                        <div class="form-grid">
                            <div class="form-group">
                                <label>Full Name<span class="required">*</span></label>
                                <input type="text" name="full_name" class="form-control" placeholder="John Doe"
                                    required>
                            </div>
                            <div class="form-group">
                                <label>Professional Title<span class="required">*</span></label>
                                <input type="text" name="job_title" class="form-control" placeholder="Software Engineer"
                                    required>
                            </div>
                        </div>
                        <div class="form-grid">
                            <div class="form-group">
                                <label>Email<span class="required">*</span></label>
                                <input type="email" name="email" class="form-control" placeholder="john.doe@email.com"
                                    required>
                            </div>
                            <div class="form-group">
                                <label>Phone<span class="required">*</span></label>
                                <input type="tel" name="phone" class="form-control" placeholder="+1 (555) 123-4567"
                                    required>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>Location<span class="required">*</span></label>
                            <input type="text" name="location" class="form-control" placeholder="New York, NY, USA"
                                required>
                        </div>
                        <div class="form-grid">
                            <div class="form-group">
                                <label>LinkedIn Profile</label>
                                <input type="url" name="linkedin" class="form-control"
                                    placeholder="linkedin.com/in/johndoe">
                            </div>
                            <div class="form-group">
                                <label>GitHub Profile</label>
                                <input type="url" name="github" class="form-control" placeholder="github.com/johndoe">
                            </div>
                        </div>
                    </div>

                    <!-- PROFESSIONAL SUMMARY -->
                    <div class="form-section">
                        <div class="section-title">Professional Summary</div>
                        <div class="form-group">
                            <label>Summary<span class="required">*</span></label>
                            <textarea name="summary" class="form-control"
                                placeholder="A brief 2-3 sentence summary highlighting your experience, skills, and career objectives..."
                                required></textarea>
                            <small class="helper-text">Keep it concise and focused on your key strengths and
                                goals</small>
                        </div>
                    </div>

                    <!-- WORK EXPERIENCE -->
                    <div class="form-section">
                        <div class="section-title">Work Experience</div>
                        <div class="dynamic-list" id="experienceList"></div>
                        <button type="button" class="btn-add" onclick="addExperience()">
                            <span>+</span>
                            <span>Add Experience</span>
                        </button>
                    </div>

                    <!-- EDUCATION -->
                    <div class="form-section">
                        <div class="section-title">Education</div>
                        <div class="dynamic-list" id="educationList"></div>
                        <button type="button" class="btn-add" onclick="addEducation()">
                            <span>+</span>
                            <span>Add Education</span>
                        </button>
                    </div>

                    <!-- SKILLS -->
                    <div class="form-section">
                        <div class="section-title">Skills</div>
                        <div class="dynamic-list" id="skillsList"></div>
                        <button type="button" class="btn-add" onclick="addSkill()">
                            <span>+</span>
                            <span>Add Skill</span>
                        </button>
                        <small class="helper-text">Add both technical and soft skills</small>
                    </div>

                    <!-- CERTIFICATIONS -->
                    <div class="form-section">
                        <div class="section-title">Certifications (Optional)</div>
                        <div class="dynamic-list" id="certificationsList"></div>
                        <button type="button" class="btn-add" onclick="addCertification()">
                            <span>+</span>
                            <span>Add Certification</span>
                        </button>
                    </div>

                    <!-- PROJECTS -->
                    <div class="form-section">
                        <div class="section-title">Projects (Optional)</div>
                        <div class="dynamic-list" id="projectsList"></div>
                        <button type="button" class="btn-add" onclick="addProject()">
                            <span>+</span>
                            <span>Add Project</span>
                        </button>
                    </div>

                    <!-- LANGUAGES -->
                    <div class="form-section">
                        <div class="section-title">Languages (Optional)</div>
                        <div class="dynamic-list" id="languagesList"></div>
                        <button type="button" class="btn-add" onclick="addLanguage()">
                            <span>+</span>
                            <span>Add Language</span>
                        </button>
                    </div>

                    <button type="submit" class="btn-submit">Generate Professional CV</button>
                </form>
            </div>
        </div>
    </div>

    <script>
        let experienceCount = 0;
        let educationCount = 0;
        let skillCount = 0;
        let certificationCount = 0;
        let projectCount = 0;
        let languageCount = 0;

        // WORK EXPERIENCE
        function addExperience() {
            experienceCount++;
            const list = document.getElementById('experienceList');
            const item = document.createElement('div');
            item.className = 'list-item';
            item.id = `experience-${experienceCount}`;
            item.innerHTML = `
                <div class="list-item-header">
                    <span class="list-item-title">Experience ${experienceCount}</span>
                    <button type="button" class="btn-remove" onclick="removeItem('experience-${experienceCount}')">×</button>
                </div>
                <div class="form-grid">
                    <div class="form-group">
                        <label>Job Title<span class="required">*</span></label>
                        <input type="text" name="exp_title[]" class="form-control" placeholder="Software Engineer" required>
                    </div>
                    <div class="form-group">
                        <label>Company<span class="required">*</span></label>
                        <input type="text" name="exp_company[]" class="form-control" placeholder="Tech Corp" required>
                    </div>
                </div>
                <div class="form-grid">
                    <div class="form-group">
                        <label>Start Date<span class="required">*</span></label>
                        <input type="text" name="exp_start[]" class="form-control" placeholder="Jan 2020" required>
                    </div>
                    <div class="form-group">
                        <label>End Date</label>
                        <input type="text" name="exp_end[]" class="form-control" placeholder="Present">
                    </div>
                </div>
                <div class="form-group">
                    <label>Achievements & Responsibilities</label>
                    <textarea name="exp_desc[]" class="form-control" placeholder="• Led development of...&#10;• Improved performance by...&#10;• Collaborated with..."></textarea>
                    <small class="helper-text">Use bullet points to list your key achievements</small>
                </div>
            `;
            list.appendChild(item);
        }

        // EDUCATION
        function addEducation() {
            educationCount++;
            const list = document.getElementById('educationList');
            const item = document.createElement('div');
            item.className = 'list-item';
            item.id = `education-${educationCount}`;
            item.innerHTML = `
                <div class="list-item-header">
                    <span class="list-item-title">Education ${educationCount}</span>
                    <button type="button" class="btn-remove" onclick="removeItem('education-${educationCount}')">×</button>
                </div>
                <div class="form-grid">
                    <div class="form-group">
                        <label>Degree<span class="required">*</span></label>
                        <input type="text" name="edu_degree[]" class="form-control" placeholder="Bachelor of Science in Computer Science" required>
                    </div>
                    <div class="form-group">
                        <label>Institution<span class="required">*</span></label>
                        <input type="text" name="edu_school[]" class="form-control" placeholder="University Name" required>
                    </div>
                </div>
                <div class="form-grid">
                    <div class="form-group">
                        <label>Start Date<span class="required">*</span></label>
                        <input type="text" name="edu_start[]" class="form-control" placeholder="Sep 2016" required>
                    </div>
                    <div class="form-group">
                        <label>End Date</label>
                        <input type="text" name="edu_end[]" class="form-control" placeholder="May 2020">
                    </div>
                </div>
                <div class="form-group">
                    <label>Additional Details</label>
                    <input type="text" name="edu_details[]" class="form-control" placeholder="GPA: 3.8/4.0, Dean's List, Relevant Coursework...">
                </div>
            `;
            list.appendChild(item);
        }

        // SKILLS
        function addSkill() {
            skillCount++;
            const list = document.getElementById('skillsList');
            const item = document.createElement('div');
            item.className = 'list-item';
            item.id = `skill-${skillCount}`;
            item.innerHTML = `
                <div class="list-item-header">
                    <span class="list-item-title">Skill Category ${skillCount}</span>
                    <button type="button" class="btn-remove" onclick="removeItem('skill-${skillCount}')">×</button>
                </div>
                <div class="form-group">
                    <label>Category<span class="required">*</span></label>
                    <input type="text" name="skill_category[]" class="form-control" placeholder="Programming Languages" required>
                </div>
                <div class="form-group">
                    <label>Skills<span class="required">*</span></label>
                    <input type="text" name="skill_items[]" class="form-control" placeholder="Python, JavaScript, Java, C++" required>
                    <small class="helper-text">Separate skills with commas</small>
                </div>
            `;
            list.appendChild(item);
        }

        // CERTIFICATIONS
        function addCertification() {
            certificationCount++;
            const list = document.getElementById('certificationsList');
            const item = document.createElement('div');
            item.className = 'list-item';
            item.id = `cert-${certificationCount}`;
            item.innerHTML = `
                <div class="list-item-header">
                    <span class="list-item-title">Certification ${certificationCount}</span>
                    <button type="button" class="btn-remove" onclick="removeItem('cert-${certificationCount}')">×</button>
                </div>
                <div class="form-grid">
                    <div class="form-group">
                        <label>Certification Name</label>
                        <input type="text" name="cert_name[]" class="form-control" placeholder="AWS Certified Solutions Architect">
                    </div>
                    <div class="form-group">
                        <label>Issuing Organization</label>
                        <input type="text" name="cert_org[]" class="form-control" placeholder="Amazon Web Services">
                    </div>
                </div>
                <div class="form-grid">
                    <div class="form-group">
                        <label>Issue Date</label>
                        <input type="text" name="cert_date[]" class="form-control" placeholder="Jan 2023">
                    </div>
                    <div class="form-group">
                        <label>Credential ID</label>
                        <input type="text" name="cert_id[]" class="form-control" placeholder="ABC123XYZ">
                    </div>
                </div>
            `;
            list.appendChild(item);
        }

        // PROJECTS
        function addProject() {
            projectCount++;
            const list = document.getElementById('projectsList');
            const item = document.createElement('div');
            item.className = 'list-item';
            item.id = `project-${projectCount}`;
            item.innerHTML = `
                <div class="list-item-header">
                    <span class="list-item-title">Project ${projectCount}</span>
                    <button type="button" class="btn-remove" onclick="removeItem('project-${projectCount}')">×</button>
                </div>
                <div class="form-grid">
                    <div class="form-group">
                        <label>Project Name</label>
                        <input type="text" name="proj_name[]" class="form-control" placeholder="E-commerce Platform">
                    </div>
                    <div class="form-group">
                        <label>Technologies</label>
                        <input type="text" name="proj_tech[]" class="form-control" placeholder="React, Node.js, MongoDB">
                    </div>
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <textarea name="proj_desc[]" class="form-control" placeholder="Brief description of the project and your role..."></textarea>
                </div>
                <div class="form-group">
                    <label>Project Link</label>
                    <input type="url" name="proj_link[]" class="form-control" placeholder="https://github.com/username/project">
                </div>
            `;
            list.appendChild(item);
        }

        // LANGUAGES
        function addLanguage() {
            languageCount++;
            const list = document.getElementById('languagesList');
            const item = document.createElement('div');
            item.className = 'list-item';
            item.id = `lang-${languageCount}`;
            item.innerHTML = `
                <div class="list-item-header">
                    <span class="list-item-title">Language ${languageCount}</span>
                    <button type="button" class="btn-remove" onclick="removeItem('lang-${languageCount}')">×</button>
                </div>
                <div class="form-grid">
                    <div class="form-group">
                        <label>Language</label>
                        <input type="text" name="lang_name[]" class="form-control" placeholder="English">
                    </div>
                    <div class="form-group">
                        <label>Proficiency</label>
                        <select name="lang_level[]" class="form-control">
                            <option value="Native">Native</option>
                            <option value="Fluent">Fluent</option>
                            <option value="Professional">Professional Working Proficiency</option>
                            <option value="Intermediate">Intermediate</option>
                            <option value="Basic">Basic</option>
                        </select>
                    </div>
                </div>
            `;
            list.appendChild(item);
        }

        // REMOVE ITEM
        function removeItem(id) {
            const item = document.getElementById(id);
            if (item) {
                item.style.animation = 'slideOut 0.3s ease';
                setTimeout(() => item.remove(), 300);
            }
        }

        // Add slideOut animation
        const style = document.createElement('style');
        style.textContent = `
            @keyframes slideOut {
                from {
                    opacity: 1;
                    transform: translateY(0);
                }
                to {
                    opacity: 0;
                    transform: translateY(-10px);
                }
            }
        `;
        document.head.appendChild(style);

        // Initialize with default entries
        window.addEventListener('DOMContentLoaded', () => {
            addExperience();
            addEducation();
            addSkill();
        });
    </script>
</body>

</html>


