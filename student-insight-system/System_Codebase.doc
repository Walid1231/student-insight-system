<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Analytics Dashboard | Insight System</title>
    <meta name="description"
        content="Student Insight System: Academic analytics dashboard for tracking CGPA, skills, study habits, and career compatibility.">

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">

    <!-- Font Awesome 6 Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- Unified Styles (sidebar, theme, layout) -->
    <link rel="stylesheet" href="{{ url_for('static', filename='css/unified_styles.css') }}?v=10">

    <!-- Analytics Dashboard Styles -->
    <link rel="stylesheet" href="{{ url_for('static', filename='css/student_analytics.css') }}?v=1">

    <!-- Chart.js 4 -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js" defer></script>

    <!-- Dashboard Charts -->
    <script src="{{ url_for('static', filename='js/student_analytics.js') }}?v=10" defer></script>
</head>

<body>
    {% set active_page = 'dashboard' %}
    {% include 'components/sidebar.html' %}

    <main class="main-content">

        <!-- ═══════════════════════════════════════════════════════
             PAGE HEADER
             ═══════════════════════════════════════════════════════ -->
        <header class="page-header" style="display:flex; align-items:flex-start; justify-content:space-between; gap:12px;">
            <div>
                <h1>Analytics Dashboard</h1>
                <p class="subtitle">Welcome, <span>{{ data.name }}</span> — here's your academic snapshot</p>
            </div>

            <!-- ── Bell Notification Button ── -->
            <div style="position:relative; flex-shrink:0;">
                <button id="notifBell"
                    title="Teacher Notifications"
                    onclick="toggleNotifCard()"
                    style="width:40px; height:40px; border-radius:50%;
                           background:rgba(99,102,241,0.1); border:1px solid rgba(99,102,241,0.25);
                           color:#6366f1; cursor:pointer; display:inline-flex;
                           align-items:center; justify-content:center; position:relative;
                           transition:background .2s;"
                    onmouseover="this.style.background='rgba(99,102,241,0.2)'"
                    onmouseout="this.style.background='rgba(99,102,241,0.1)'">
                    <i class="fas fa-bell" style="font-size:15px;"></i>
                    <span id="notifBadge"
                          style="display:none; position:absolute; top:-3px; right:-3px;
                                 background:#ef4444; color:white; border-radius:50%;
                                 min-width:17px; height:17px; font-size:9px; font-weight:700;
                                 align-items:center; justify-content:center;
                                 border:2px solid #0f1117; padding:0 2px;">0</span>
                </button>

                <!-- Popup note card -->
                <div id="notifCard"
                     style="display:none; position:absolute; top:52px; right:0;
                            width:340px; background:var(--bg-surface, #ffffff);
                            border:1px solid var(--border-light, #e5e7eb); border-radius:12px;
                            box-shadow:0 12px 36px rgba(0,0,0,0.08); z-index:9999;
                            overflow:hidden; animation:fadeInDown .15s ease;">
                    <div style="padding:14px 18px; border-bottom:1px solid var(--border-light, #f3f4f6);
                                display:flex; align-items:center; justify-content:space-between;
                                background:var(--bg-body, #f9fafb);">
                        <span style="font-weight:600; font-size:14px; color:var(--text-dark, #111827);">
                            Recent Notes
                        </span>
                        <a href="/student/notifications"
                           style="font-size:12px; color:var(--primary-navy, #6366f1); text-decoration:none; font-weight:500;">
                            View all &rarr;
                        </a>
                    </div>
                    <div id="notifCardBody" style="display:flex; flex-direction:column; background:var(--bg-surface, #ffffff);">
                        <div style="padding:20px; text-align:center; color:var(--text-muted, #9ca3af); font-size:13px;">
                            <i class="fas fa-spinner fa-spin"></i> Loading...
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <style>
            @keyframes fadeInDown {
                from { opacity:0; transform:translateY(-8px); }
                to   { opacity:1; transform:translateY(0); }
            }
            .notif-item {
                padding: 14px 18px;
                border-bottom: 1px solid var(--border-light, #f3f4f6);
                display: flex;
                gap: 12px;
                align-items: flex-start;
                text-decoration: none;
                transition: background 0.15s;
            }
            .notif-item:last-child {
                border-bottom: none;
            }
            .notif-item:hover {
                background: var(--bg-body, #f9fafb);
            }
            
            /* Visual hierarchy */
            .notif-item.rank-0 {
                background: rgba(99,102,241,0.03);
                border-left: 3px solid #6366f1;
            }
            html[data-theme="dark"] .notif-item.rank-0 { background: rgba(99,102,241,0.1); }
            .notif-item.rank-0 .n-text {
                font-weight: 500;
                color: var(--text-dark, #1f2937);
            }
            
            .notif-item.rank-1 { background: transparent; border-left: 3px solid transparent; }
            .notif-item.rank-1 .n-text { color: var(--text-muted, #4b5563); }
            
            .notif-item.rank-older {
                background: transparent;
                border-left: 3px solid transparent;
                opacity: 0.75;
            }
            .notif-item.rank-older .n-text { color: var(--text-muted, #6b7280); font-size:12.5px; }

            .n-avatar {
                width: 32px;
                height: 32px;
                border-radius: 8px;
                background: #ede9fe;
                color: #5b21b6;
                display: flex;
                align-items: center;
                justify-content: center;
                font-weight: 600;
                font-size: 11px;
                flex-shrink: 0;
            }
        </style>

        <script>
            let _notifData = null;
            let _notifCardOpen = false;

            async function loadNotifData() {
                if (_notifData) return _notifData;
                try {
                    const res = await fetch('/api/student/notifications');
                    if (!res.ok) return null;
                    _notifData = await res.json();
                    
                    const badge = document.getElementById('notifBadge');
                    if (badge && _notifData.unread_count > 0) {
                        badge.textContent = _notifData.unread_count > 9 ? '9+' : _notifData.unread_count;
                        badge.style.display = 'flex';
                    }
                    return _notifData;
                } catch (e) { return null; }
            }

            async function toggleNotifCard() {
                const card = document.getElementById('notifCard');
                const body = document.getElementById('notifCardBody');
                _notifCardOpen = !_notifCardOpen;
                card.style.display = _notifCardOpen ? 'block' : 'none';

                if (_notifCardOpen) {
                    const data = await loadNotifData();
                    if (!data || !data.recent || data.recent.length === 0) {
                        body.innerHTML = '<div style="padding:24px; text-align:center; color:var(--text-muted); font-size:13px;">No new notes.</div>';
                        return;
                    }
                    
                    // Render recent list with visual hierarchy styling
                    let html = '';
                    data.recent.forEach((n, idx) => {
                        let rankClass = 'rank-older';
                        if (idx === 0) rankClass = 'rank-0';
                        else if (idx === 1) rankClass = 'rank-1';
                        
                        const init = (n.teacher_name || 'T').substring(0, 2).toUpperCase();
                        const snippet = n.content.length > 55 ? n.content.substring(0, 55) + '...' : n.content;
                        
                        html += `
                        <a href="/student/notifications" class="notif-item ${rankClass}">
                            <div class="n-avatar">${init}</div>
                            <div style="flex:1; min-width:0;">
                                <div style="display:flex; justify-content:space-between; margin-bottom:2px;">
                                    <span style="font-size:12px; font-weight:600; color:var(--text-dark);">${n.teacher_name}</span>
                                    <span style="font-size:11px; color:var(--text-muted);">${n.created_at}</span>
                                </div>
                                <div class="n-text" style="font-size:13px; line-height:1.4;">
                                    ${n.is_read ? '' : '<span style="display:inline-block; width:6px; height:6px; background:#4f46e5; border-radius:50%; margin-right:4px;"></span>'}
                                    ${snippet}
                                </div>
                            </div>
                        </a>`;
                    });
                    
                    body.innerHTML = html;
                }
            }

            // Close popup when clicking outside
            document.addEventListener('click', function(e) {
                if (_notifCardOpen && !e.target.closest('#notifBell') && !e.target.closest('#notifCard')) {
                    document.getElementById('notifCard').style.display = 'none';
                    _notifCardOpen = false;
                }
            });

            // Load badge count on page load without opening card
            loadNotifData();
        </script>



        <!-- ═══════════════════════════════════════════════════════
             QUICK STATS BAR
             ═══════════════════════════════════════════════════════ -->
        <section class="stats-bar" id="statsBar">
            <div class="stat-card">
                <div class="stat-icon blue">
                    <i class="fas fa-graduation-cap"></i>
                </div>
                <div>
                    <div class="stat-value">{{ data.cgpa or '—' }}</div>
                    <div class="stat-label">Current CGPA</div>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon green">
                    <i class="fas fa-book-open"></i>
                </div>
                <div>
                    <div class="stat-value">{{ data.total_credits }}</div>
                    <div class="stat-label">Credits Earned</div>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon purple">
                    <i class="fas fa-bullseye"></i>
                </div>
                <div>
                    <div class="stat-value">{{ data.goals_count }}</div>
                    <div class="stat-label">Goals Active</div>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon amber">
                    <i class="fas fa-clock"></i>
                </div>
                <div>
                    <div class="stat-value">{{ data.sessions_count }}</div>
                    <div class="stat-label">Study Sessions</div>
                </div>
            </div>
        </section>


        <!-- ═══════════════════════════════════════════════════════
             DASHBOARD GRID  —  3-Column Responsive
             ═══════════════════════════════════════════════════════ -->
        <div class="dashboard-grid" id="dashboardGrid">

            <!-- ┌─────────────────────── ROW 1 ───────────────────────┐ -->

            <!-- 1 ▸ CGPA Trend -->
            <article class="dash-card" id="cardCgpaTrend">
                <div class="card-header">
                    <h2 class="card-title">
                        <i class="fas fa-chart-line" style="color: var(--accent-blue);"></i>
                        CGPA Trend
                    </h2>
                    {% if data.has_grades and data.cgpa_values|length > 1 %}
                    <span class="card-badge">{{ data.cgpa_values|length }} Semesters</span>
                    {% endif %}
                </div>
                {% if data.has_grades %}
                <div class="chart-wrap">
                    <canvas id="cgpaTrendChart"></canvas>
                </div>
                <div class="chart-annotation">
                    Current: <span id="cgpaCurrentValue">{{ data.cgpa }}</span>
                    {% if data.cgpa_values|length > 1 %}
                    ({% if data.cgpa_values[-1] >= data.cgpa_values[-2] %}&uarr;{% else %}&darr;{% endif %})
                    {% endif %}
                    <small>Semester-over-semester performance</small>
                </div>
                {% else %}
                <div class="empty-state">
                    <i class="fas fa-chart-line"></i>
                    <p>Add your grades to see your semester CGPA trend.</p>
                    <a href="{{ url_for('dashboard.goals_grades') }}"><i class="fas fa-plus"></i> Add Grades</a>
                </div>
                {% endif %}
            </article>

            <!-- 2 ▸ Strength vs Weakness Radar -->
            <article class="dash-card" id="cardSkillRadar">
                <div class="card-header">
                    <h2 class="card-title">
                        <i class="fas fa-crosshairs" style="color: var(--accent-green);"></i>
                        Strength vs Weakness
                    </h2>
                    <span class="card-badge">Radar</span>
                </div>
                {% if data.has_skills %}
                <div class="chart-wrap">
                    <canvas id="skillRadarChart"></canvas>
                </div>
                {% else %}
                <div class="empty-state">
                    <i class="fas fa-crosshairs"></i>
                    <p>Select your skills in Goals & Grades to see your radar.</p>
                    <a href="{{ url_for('dashboard.goals_grades') }}"><i class="fas fa-star"></i> Pick Skills</a>
                </div>
                {% endif %}
            </article>

            <!-- 3 ▸ Core vs GED Distribution -->
            <article class="dash-card" id="cardCoreGed">
                <div class="card-header">
                    <h2 class="card-title">
                        <i class="fas fa-circle-half-stroke" style="color: var(--accent-purple);"></i>
                        Core vs GED Distribution
                    </h2>
                </div>
                {% if data.has_grades %}
                <div class="chart-wrap">
                    <canvas id="coreGedChart"></canvas>
                </div>
                {% else %}
                <div class="empty-state">
                    <i class="fas fa-layer-group"></i>
                    <p>Add courses with different types to see distribution.</p>
                    <a href="{{ url_for('dashboard.goals_grades') }}"><i class="fas fa-plus"></i> Add Grades</a>
                </div>
                {% endif %}
            </article>


            <!-- ┌─────────────────────── ROW 2 ───────────────────────┐ -->

            <!-- 4 ▸ Weekly Study Hours -->
            <article class="dash-card" id="cardWeeklyHours">
                <div class="card-header">
                    <h2 class="card-title">
                        <i class="fas fa-calendar-week" style="color: var(--accent-purple);"></i>
                        Weekly Study Hours
                    </h2>
                    <span class="card-badge">Last 7 Days</span>
                </div>
                {% if data.has_recent_sessions %}
                <div class="chart-wrap">
                    <canvas id="weeklyHoursChart"></canvas>
                </div>
                {% else %}
                <div class="empty-state">
                    <i class="fas fa-calendar-week"></i>
                    <p>No sessions logged in the last 7 days.</p>
                    <a href="{{ url_for('dashboard.student_routine') }}"><i class="fas fa-plus"></i> Log Session</a>
                </div>
                {% endif %}
            </article>

            <!-- 5 ▸ Skill Effort Distribution -->
            <article class="dash-card" id="cardSkillEffort">
                <div class="card-header">
                    <h2 class="card-title">
                        <i class="fas fa-fire" style="color: var(--accent-amber);"></i>
                        Skill Effort Distribution
                    </h2>
                </div>
                {% if data.effort_labels %}
                <div class="chart-wrap">
                    <canvas id="skillEffortChart"></canvas>
                </div>
                {% else %}
                <div class="empty-state">
                    <i class="fas fa-fire"></i>
                    <p>Log study sessions with a skill tag to see effort distribution.</p>
                    <a href="{{ url_for('dashboard.student_routine') }}"><i class="fas fa-plus"></i> Log Session</a>
                </div>
                {% endif %}
            </article>

            <!-- 6 ▸ Career Compatibility -->
            <article class="dash-card career-compat-premium" id="cardCareer">
                <div class="career-premium-header">
                    <i class="fas fa-briefcase" style="color: #6366f1;"></i> CAREER COMPATIBILITY
                </div>
                {% if data.careers and data.careers|length > 0 %}
                {% set top_career = data.careers[0] %}
                <div class="career-premium-body">
                    <div class="career-premium-role">{{ top_career.role }}</div>

                    <div class="career-premium-score-wrapper">
                        <div class="career-premium-score">{{ top_career.match }}% Match</div>
                    </div>

                    <div class="career-premium-bar-wrapper">
                        <div class="career-premium-track">
                            <div class="career-premium-fill" style="width: {{ top_career.match }}%;"></div>
                        </div>
                        <div class="career-premium-bar-text">{{ top_career.match }}%</div>
                    </div>

                    <div class="career-premium-insights">
                        <div class="insight-line">
                            <span class="insight-dot green"></span>
                            <span class="insight-text">+12% above average in Math</span>
                        </div>
                        <div class="insight-line">
                            <span class="insight-dot amber"></span>
                            <span class="insight-text">-8% below required in System Design</span>
                        </div>
                    </div>
                </div>
                {% else %}
                <div class="empty-state">
                    <i class="fas fa-briefcase"></i>
                    <p>Add goals and skills to see career compatibility scores.</p>
                    <a href="{{ url_for('dashboard.goals_grades') }}"><i class="fas fa-star"></i> Goals & Skills</a>
                </div>
                {% endif %}
            </article>


            <!-- ┌─────────────────────── ROW 3 ───────────────────────┐ -->

            <!-- 7 ▸ Burnout Risk Gauge -->
            <article class="dash-card" id="cardBurnout">
                <div class="card-header">
                    <h2 class="card-title">
                        <i class="fas fa-heartbeat" style="color: var(--accent-red);"></i>
                        Burnout Risk Gauge
                    </h2>
                </div>
                {% if data.has_checkin %}
                <div class="gauge-center">
                    <div class="gauge-canvas-wrap">
                        <canvas id="burnoutGauge"></canvas>
                    </div>
                    <div id="burnoutLabel"
                        class="gauge-value-label {{ 'low' if data.burnout_pct < 40 else 'medium' if data.burnout_pct < 70 else 'high' }}">
                        {{ data.burnout_label }}
                    </div>
                    <div id="burnoutDesc" class="gauge-desc">{{ data.burnout_message }}</div>
                </div>
                {% else %}
                <div class="empty-state">
                    <i class="fas fa-heartbeat"></i>
                    <p>Submit your Weekly Check-in for a burnout risk assessment.</p>
                    <a href="{{ url_for('dashboard.weekly_checkin') }}"><i class="fas fa-clipboard-check"></i> Check
                        In</a>
                </div>
                {% endif %}
            </article>

            <!-- 8 ▸ Goal Achievability Probability -->
            <article class="dash-card span-2" id="cardGoal">
                <div class="card-header">
                    <h2 class="card-title">
                        <i class="fas fa-trophy" style="color: var(--accent-amber);"></i>
                        Goal Achievability Probability
                    </h2>
                    {% if data.has_goals %}
                    <span class="card-badge">Bell Curve</span>
                    {% endif %}
                </div>
                {% if data.has_goals %}
                <div class="chart-wrap-sm">
                    <canvas id="goalCurveChart"></canvas>
                </div>
                <div class="goal-center">
                    <div id="goalProbValue" class="goal-big-number">{{ data.goal_prob }}%</div>
                    <div class="goal-label">Likelihood of Achievement</div>
                    <div id="goalTargetInfo" class="goal-target-info">
                        Target CGPA <strong>{{ data.target_gpa }}</strong>
                        {% if data.target_career %} &middot; {{ data.target_career }}{% endif %}
                    </div>
                </div>
                {% else %}
                <div class="empty-state">
                    <i class="fas fa-trophy"></i>
                    <p>Set a career goal in Goals & Grades to see your achievability score.</p>
                    <a href="{{ url_for('dashboard.goals_grades') }}"><i class="fas fa-bullseye"></i> Set Goal</a>
                </div>
                {% endif %}
            </article>

        </div><!-- /.dashboard-grid -->


        <!-- ═══════════════════════════════════════════════════════
             DATA INJECTION — Backend → JS
             ═══════════════════════════════════════════════════════ -->
        <script>
            // ── Data Injection (Backend → JS) ──
            window.DASH = {
                cgpa_labels: {{ data.cgpa_labels | tojson }},
                cgpa_values: {{ data.cgpa_values | tojson }},
                radar_labels: {{ data.radar_labels | tojson }},
                radar_scores: {{ data.radar_scores | tojson }},
                core_count: {{ data.core_count | tojson }},
                ged_count: {{ data.ged_count | tojson }},
                elective_count: {{ data.elective_count | tojson }},
                weekly_labels: {{ data.weekly_labels | tojson }},
                weekly_hours: {{ data.weekly_hours | tojson }},
                effort_labels: {{ data.effort_labels | tojson }},
                effort_week_a: {{ data.effort_week_a | tojson }},
                effort_week_b: {{ data.effort_week_b | tojson }},
                careers: {{ data.careers | tojson }},
                burnout_pct: {{ data.burnout_pct | tojson }},
                goal_prob: {{ data.goal_prob | tojson }},
                target_gpa: {{ data.target_gpa | tojson }},
                target_career: {{ data.target_career | tojson }}
            };

            // ── Init charts ──
            // The SPA router (sidebar.html) calls initStudentDashboardCharts() after
            // injecting this page's HTML into .main-content. For a hard first load,
            // student_analytics.js fires on DOMContentLoaded. We only need to ensure
            // Chart.js is available; if it landed via SPA nav it already is.
            (function ensureChartsInit() {
                function tryInit() {
                    if (typeof initStudentDashboardCharts === 'function') {
                        initStudentDashboardCharts();
                    }
                }
                function loadScript(id, src, cb) {
                    if (document.getElementById(id)) { cb(); return; }
                    var s = document.createElement('script');
                    s.id = id; s.src = src; s.onload = cb;
                    document.head.appendChild(s);
                }
                // Only run in SPA mode (DOM already ready). First-page-load is handled
                // by the DOMContentLoaded listener in student_analytics.js.
                if (document.readyState !== 'loading') {
                    if (typeof Chart === 'undefined') {
                        loadScript('_chartjs', 'https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js', function () {
                            if (typeof initStudentDashboardCharts === 'undefined') {
                                loadScript('_analyticsjs', '{{ url_for("static", filename="js/student_analytics.js") }}?v=11', tryInit);
                            } else { tryInit(); }
                        });
                    } else {
                        // Chart.js already loaded — defer one tick so the SPA router's
                        // own final call doesn't race with us.
                        setTimeout(tryInit, 0);
                    }
                }
            })();
        </script>

    </main>

</body>

</html>


